---
/**
 * Weekly Spread Display Component
 * 
 * Renders the 11-card weekly spread (7 planetary + 4 domain)
 */

interface Props {
  planetaryCards: Record<string, string>;
  domainCards: Record<string, string>;
  currentDay?: string;
  compact?: boolean;
}

const { planetaryCards, domainCards, currentDay, compact = false } = Astro.props;

const weekDays = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
const domains = ['Body', 'Mind', 'Heart', 'Spirit'];
---

<div class:list={['spread-display', { compact }]}>
  <div class="planetary-row">
    {weekDays.map((day) => (
      <div class:list={['card-slot', { 'is-current': day === currentDay }]}>
        <span class="slot-label">{compact ? day.slice(0, 1) : day.slice(0, 3)}</span>
        <span class="card-name">{planetaryCards[day]}</span>
      </div>
    ))}
  </div>
  
  <div class="domain-row">
    {domains.map((domain) => (
      <div class={`card-slot domain-${domain.toLowerCase()}`}>
        <span class="slot-label">{domain}</span>
        <span class="card-name">{domainCards[domain]}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .spread-display {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  
  .planetary-row {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: var(--space-sm);
  }
  
  .domain-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-sm);
  }
  
  .card-slot {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-md);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    transition: all 0.2s ease;
  }
  
  .card-slot.is-current {
    border-color: var(--color-gold);
    box-shadow: 0 0 12px rgba(201, 162, 39, 0.2);
  }
  
  .slot-label {
    font-family: var(--font-display);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-dim);
  }
  
  .card-name {
    font-size: 0.85rem;
    color: var(--color-text);
    line-height: 1.3;
  }
  
  /* Domain colors */
  .card-slot.domain-body { border-top: 3px solid var(--color-accent-body); }
  .card-slot.domain-mind { border-top: 3px solid var(--color-accent-mind); }
  .card-slot.domain-heart { border-top: 3px solid var(--color-accent-heart); }
  .card-slot.domain-spirit { border-top: 3px solid var(--color-accent-spirit); }
  
  /* Compact mode */
  .compact .card-slot {
    padding: var(--space-sm);
  }
  
  .compact .card-name {
    font-size: 0.75rem;
  }
  
  @media (max-width: 768px) {
    .planetary-row {
      grid-template-columns: repeat(4, 1fr);
    }
    
    .domain-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
