---
/**
 * Cycle Timeline Detail Page
 *
 * Shows full details of a reading cycle: all 7 planetary entries,
 * their completion status, cards assigned, and cycle synthesis.
 *
 * The [start] param receives a cycle_id UUID (V2).
 */
import Layout from '../../../layouts/Layout.astro';
import { sacredJourney } from '../../../lib/sacred-journey';
import type { CycleTimelineResponse } from '../../../lib/sacred-journey';
import { DOMAINS } from '../../../lib/domain-utils';

const { start: cycleId } = Astro.params;

let timeline: CycleTimelineResponse | null = null;
let error: string | null = null;

try {
  timeline = await sacredJourney.getCycleTimeline(cycleId!);
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load cycle timeline';
}

// Planet metadata for display
const PLANET_INFO: Record<string, { symbol: string; theme: string }> = {
  Sun:     { symbol: '\u2609', theme: 'Identity, vitality, core self' },
  Moon:    { symbol: '\u263D', theme: 'Emotions, intuition, inner world' },
  Mars:    { symbol: '\u2642', theme: 'Action, drive, courage' },
  Mercury: { symbol: '\u263F', theme: 'Communication, intellect, learning' },
  Jupiter: { symbol: '\u2643', theme: 'Expansion, wisdom, abundance' },
  Venus:   { symbol: '\u2640', theme: 'Love, values, beauty' },
  Saturn:  { symbol: '\u2644', theme: 'Structure, discipline, mastery' },
};

function formatDateTime(isoString: string | null): string {
  if (!isoString) return '';
  const datePart = isoString.split('T')[0];
  const [year, month, day] = datePart.split('-').map(Number);
  return new Date(year, month - 1, day).toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  });
}

function formatDateShort(isoString: string | null): string {
  if (!isoString) return '';
  const datePart = isoString.split('T')[0];
  const [year, month, day] = datePart.split('-').map(Number);
  return new Date(year, month - 1, day).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
  });
}

function formatDuration(hours: number): string {
  if (hours < 1) return 'Less than 1 hour';
  if (hours < 24) return `${Math.round(hours)} hours`;
  const days = Math.floor(hours / 24);
  const remainingHours = Math.round(hours % 24);
  if (remainingHours === 0) return `${days} day${days !== 1 ? 's' : ''}`;
  return `${days} day${days !== 1 ? 's' : ''}, ${remainingHours} hr${remainingHours !== 1 ? 's' : ''}`;
}

// Find the next available entry for the "continue" action
const nextEntry = timeline?.entries.find(e => e.status === 'available' || e.status === 'active' || e.status === 'integrating') ?? null;
---

<Layout title={`Cycle Timeline - Paths of Reverence`}>
  <div class="cycle-detail-page">
    <header class="page-header">
      <a href="/history" class="back-link">&larr; Back to Archive</a>
      <h1>Cycle Timeline</h1>
    </header>

    {error ? (
      <div class="error-state">
        <p>{error}</p>
        <p class="hint">This cycle may not exist or could not be loaded.</p>
        <a href="/history" class="btn btn-primary">Back to Archive</a>
      </div>
    ) : timeline ? (
      <div class="cycle-content">
        <!-- Cycle Header / Progress -->
        <section class="progress-section">
          <div class="progress-stats">
            <div class="stat">
              <span class="stat-value">{timeline.entries_completed}/7</span>
              <span class="stat-label">Entries Complete</span>
            </div>
            <div class="stat">
              <span class="stat-value">
                {timeline.total_duration_hours > 0 ? formatDuration(timeline.total_duration_hours) : '--'}
              </span>
              <span class="stat-label">Duration</span>
            </div>
            <div class="stat">
              <span class={`status-badge status-${timeline.status}`}>
                {timeline.status}
              </span>
            </div>
          </div>

          <div class="cycle-dates">
            <span>Started: {formatDateTime(timeline.created_at)}</span>
            {timeline.completed_at && (
              <span>Completed: {formatDateTime(timeline.completed_at)}</span>
            )}
          </div>

          <div class="progress-bar-container">
            <div class="progress-bar">
              <div
                class="progress-fill"
                style={`width: ${(timeline.entries_completed / 7) * 100}%`}
              ></div>
            </div>
          </div>
        </section>

        <!-- Planetary Entries -->
        <section class="entries-section">
          <h2>Planetary Entries</h2>
          <div class="entries-grid">
            {timeline.entries.map((entry) => {
              const info = PLANET_INFO[entry.planet] || { symbol: '?', theme: '' };
              const isComplete = entry.status === 'complete';
              const isActive = entry.status === 'active' || entry.status === 'integrating';
              const cardName = timeline.planetary_cards[String(entry.sequence)] ?? null;

              return (
                <div class:list={['entry-card', { complete: isComplete, active: isActive }]}>
                  <span class="planet-symbol">{info.symbol}</span>
                  <span class="planet-name">{entry.planet}</span>
                  <span class="entry-sequence">Entry {entry.sequence}</span>
                  {cardName && (
                    <span class="card-name" title={cardName}>{cardName}</span>
                  )}
                  <div class="entry-meta">
                    <span class={`entry-status status-${entry.status}`}>{entry.status}</span>
                    {entry.interpretations_completed > 0 && (
                      <span class="interp-count" title="Interpretations completed">
                        {entry.interpretations_completed}/4
                      </span>
                    )}
                    {entry.has_synthesis && (
                      <span class="synthesis-indicator" title="Synthesis complete">S</span>
                    )}
                  </div>
                  {entry.started_at && (
                    <span class="entry-date">{formatDateShort(entry.started_at)}</span>
                  )}
                  <div class="entry-actions">
                    {isComplete ? (
                      <a href={`/practice/${entry.entry_id}`} class="day-status complete" title="View completed entry">&#10003;</a>
                    ) : isActive ? (
                      <a href={`/practice/${entry.entry_id}`} class="btn btn-small btn-primary">Continue</a>
                    ) : (
                      <span class="day-status pending">&mdash;</span>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </section>

        <!-- Planetary Cards -->
        {Object.keys(timeline.planetary_cards).length > 0 && (
          <section class="cards-section">
            <h2>Planetary Cards</h2>
            <div class="cards-list">
              {Object.entries(timeline.planetary_cards).map(([seq, cardName]) => {
                const entry = timeline.entries.find(e => e.sequence === Number(seq));
                const planet = entry?.planet ?? `Sequence ${seq}`;
                const info = PLANET_INFO[planet] || { symbol: '?', theme: '' };
                return (
                  <div class="card-item">
                    <span class="card-planet">{info.symbol} {planet}</span>
                    <span class="card-value">{cardName}</span>
                  </div>
                );
              })}
            </div>
          </section>
        )}

        <!-- Domain Cards -->
        {Object.keys(timeline.domain_cards).length > 0 && (
          <section class="cards-section">
            <h2>Domain Cards</h2>
            <div class="cards-list">
              {DOMAINS.map((domain) => {
                const cardName = (timeline.domain_cards as Record<string, string>)[domain];
                return cardName ? (
                  <div class="card-item">
                    <span class="card-domain">{domain}</span>
                    <span class="card-value">{cardName}</span>
                  </div>
                ) : null;
              })}
            </div>
          </section>
        )}

        <!-- Cycle Synthesis -->
        {timeline.has_cycle_synthesis && (
          <section class="synthesis-section">
            <h2>Cycle Synthesis</h2>
            <p class="synthesis-note">This cycle has a completed synthesis.</p>
          </section>
        )}

        <!-- Actions -->
        {timeline.status === 'active' && nextEntry && (
          <section class="actions-section">
            <a href={`/practice/${nextEntry.entry_id}`} class="btn btn-primary">
              Continue — {PLANET_INFO[nextEntry.planet]?.symbol} {nextEntry.planet}
            </a>
          </section>
        )}

        {timeline.status === 'complete' && (
          <section class="actions-section">
            <p class="complete-message">&#10022; This cycle's practice is complete &#10022;</p>
          </section>
        )}
      </div>
    ) : (
      <div class="empty-state">
        <p>No data found for this cycle.</p>
      </div>
    )}
  </div>
</Layout>

<style>
  .cycle-detail-page {
    max-width: 800px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: var(--space-2xl);
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .back-link:hover {
    color: var(--color-gold);
  }

  .progress-section {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .progress-stats {
    display: flex;
    justify-content: space-around;
    align-items: center;
    margin-bottom: var(--space-lg);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-gold);
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cycle-dates {
    display: flex;
    justify-content: center;
    gap: var(--space-xl);
    font-size: 0.85rem;
    color: var(--color-text-dim);
    margin-bottom: var(--space-lg);
  }

  .status-badge {
    font-family: var(--font-display);
    font-size: 0.85rem;
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--card-radius);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .status-badge.status-active {
    background: rgba(201, 162, 39, 0.2);
    color: var(--color-gold);
  }

  .status-badge.status-complete {
    background: rgba(124, 152, 133, 0.2);
    color: var(--color-accent-body);
  }

  .progress-bar-container {
    padding: 0 var(--space-md);
  }

  .progress-bar {
    height: 8px;
    background: var(--color-bg-card);
    border-radius: 4px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-gold-dim), var(--color-gold));
    transition: width 0.3s ease;
  }

  .entries-section h2,
  .cards-section h2,
  .synthesis-section h2 {
    margin-bottom: var(--space-lg);
  }

  .entries-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
  }

  .entry-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    text-align: center;
  }

  .entry-card.complete {
    border-color: var(--color-accent-body);
  }

  .entry-card.active {
    border-color: var(--color-gold);
    box-shadow: 0 0 12px rgba(201, 162, 39, 0.2);
  }

  .planet-symbol {
    font-size: 1.5rem;
    line-height: 1;
  }

  .planet-name {
    font-family: var(--font-display);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text);
  }

  .entry-sequence {
    font-size: 0.7rem;
    color: var(--color-text-dim);
  }

  .card-name {
    font-size: 0.7rem;
    color: var(--color-gold-dim);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .entry-meta {
    display: flex;
    gap: var(--space-xs);
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }

  .entry-status {
    font-size: 0.65rem;
    padding: 2px 6px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .entry-status.status-complete {
    background: rgba(124, 152, 133, 0.2);
    color: var(--color-accent-body);
  }

  .entry-status.status-active {
    background: rgba(201, 162, 39, 0.2);
    color: var(--color-gold);
  }

  .entry-status.status-integrating {
    background: rgba(201, 162, 39, 0.15);
    color: var(--color-gold-dim);
  }

  .entry-status.status-available {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-text-dim);
  }

  .interp-count {
    font-size: 0.65rem;
    color: var(--color-text-dim);
  }

  .synthesis-indicator {
    font-size: 0.6rem;
    font-weight: bold;
    color: var(--color-accent-body);
    border: 1px solid var(--color-accent-body);
    border-radius: 50%;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .entry-date {
    font-size: 0.7rem;
    color: var(--color-text-dim);
  }

  .entry-actions {
    margin-top: var(--space-xs);
  }

  .day-status {
    font-size: 1.2rem;
    text-decoration: none;
  }

  .day-status.complete {
    color: var(--color-accent-body);
  }

  .day-status.pending {
    color: var(--color-text-dim);
  }

  a.day-status.complete:hover {
    color: var(--color-gold);
  }

  .btn-small {
    font-size: 0.7rem;
    padding: var(--space-xs) var(--space-sm);
  }

  /* Cards sections */
  .cards-section {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .cards-list {
    display: grid;
    gap: var(--space-sm);
  }

  .card-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-card);
    border-radius: var(--card-radius);
  }

  .card-planet,
  .card-domain {
    font-family: var(--font-display);
    font-size: 0.85rem;
    color: var(--color-text);
  }

  .card-value {
    font-size: 0.85rem;
    color: var(--color-gold);
  }

  /* Synthesis section */
  .synthesis-section {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-accent-body);
    border-radius: var(--card-radius);
    padding: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .synthesis-note {
    color: var(--color-text-dim);
    font-style: italic;
  }

  .actions-section {
    text-align: center;
    margin-top: var(--space-2xl);
  }

  .complete-message {
    color: var(--color-accent-body);
    font-family: var(--font-display);
    letter-spacing: 0.1em;
  }

  .error-state, .empty-state {
    text-align: center;
    padding: var(--space-2xl);
    background: var(--color-bg-elevated);
    border: 1px dashed var(--color-border);
    border-radius: var(--card-radius);
  }

  .hint {
    color: var(--color-text-dim);
    margin-bottom: var(--space-lg);
  }

  @media (max-width: 768px) {
    .entries-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .cycle-dates {
      flex-direction: column;
      align-items: center;
      gap: var(--space-xs);
    }
  }

  @media (max-width: 480px) {
    .entries-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .progress-stats {
      flex-direction: column;
      gap: var(--space-md);
    }
  }
</style>
