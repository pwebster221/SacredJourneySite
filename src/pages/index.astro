---
/**
 * Paths of Reverence - Home / Active Cycle
 *
 * Displays the current active reading cycle and the current progression entry
 * (the active planet in sequence), with action prompts for the next step.
 */
import Layout from '../layouts/Layout.astro';
import { sacredJourney } from '../lib/sacred-journey';

// Fetch active cycle and progress from V2 API
let activeCycle = null;
let progress = null;
let currentEntry = null;
let error = null;

try {
  const { active_cycles } = await sacredJourney.getActiveCycles();
  activeCycle = active_cycles[0] ?? null;
  if (activeCycle) {
    progress = await sacredJourney.getCycleProgress(activeCycle.cycle_id);
    currentEntry = progress?.current_entry ?? null;
  }
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load active cycle';
}

// Planet sequence (1–7) — used as fallback labels
const PLANET_SEQUENCE = ['Sun', 'Moon', 'Mars', 'Mercury', 'Jupiter', 'Venus', 'Saturn'];

// Count completed entries
const completedCount = progress?.entries.filter(e => e.status === 'complete').length ?? 0;

// Format cycle start date from ISO timestamp
function formatCycleDate(isoString: string): string {
  const date = new Date(isoString);
  return date.toLocaleDateString('en-US', {
    weekday: 'long',
    month: 'long',
    day: 'numeric',
  });
}

// Map entry status to a human-readable action label
function entryActionLabel(status: string): string {
  switch (status) {
    case 'available': return 'Begin';
    case 'active': return 'Continue';
    case 'integrating': return 'Integrate';
    default: return 'View';
  }
}
---

<Layout title="Today's Practice - Paths of Reverence">
  <div class="spread-page">
    {error ? (
      <div class="error-state">
        <h2>Connection Issue</h2>
        <p>{error}</p>
        <p class="hint">Ensure the Sacred Journey API is accessible.</p>
      </div>
    ) : !activeCycle ? (
      <div class="empty-state">
        <div class="empty-icon">✦</div>
        <h2>Begin a New Cycle</h2>
        <p>No active reading cycle. Draw your cards and start your planetary journey.</p>
        <a href="/practice/new-week" class="btn btn-primary">Begin New Cycle</a>
        <a href="/history" class="btn" style="margin-left: var(--space-md);">View Archive</a>
      </div>
    ) : (
      <>
        {/* Cycle Overview */}
        <section class="weekly-overview">
          <header class="section-header">
            <h1>Cycle begun {formatCycleDate(activeCycle.created_at)}</h1>
            <div class="week-progress">
              <span class="progress-text">{completedCount}/7 planets complete</span>
              <div class="progress-bar">
                <div class="progress-fill" style={`width: ${(completedCount / 7) * 100}%`}></div>
              </div>
            </div>
          </header>

          {/* Planetary Sequence Row */}
          <div class="planetary-spread">
            <h2>Planetary Sequence</h2>
            <div class="card-row">
              {progress ? (
                progress.entries.map((entry) => (
                  <div class={`spread-card ${entry.entry_id === currentEntry?.entry_id ? 'is-today' : ''} status-card-${entry.status}`}>
                    <span class="card-day">{entry.sequence}</span>
                    <span class="card-name">{entry.planet}</span>
                    {entry.status === 'complete' && <span class="card-status-icon">✓</span>}
                  </div>
                ))
              ) : (
                PLANET_SEQUENCE.map((planet, i) => (
                  <div class="spread-card">
                    <span class="card-day">{i + 1}</span>
                    <span class="card-name">{planet}</span>
                  </div>
                ))
              )}
            </div>
          </div>
        </section>

        {/* Current Entry / Active Planet */}
        {currentEntry ? (
          <section class="today-practice">
            <header class="section-header">
              <h2>Current Planet — {currentEntry.planet}</h2>
              <span class={`status-badge status-${currentEntry.status}`}>
                {currentEntry.status}
              </span>
            </header>

            <div class="today-cards">
              <div class="planetary-focus">
                <span class="label">Sequence Position</span>
                <span class="value">{currentEntry.sequence} of 7 — {currentEntry.planet}</span>
              </div>
            </div>

            {/* Action buttons */}
            <div class="practice-actions">
              <a href={`/practice/session/${currentEntry.entry_id}`} class="btn btn-primary">
                Start Chat Session
              </a>
              <a href={`/practice/${currentEntry.entry_id}`} class="btn">
                {entryActionLabel(currentEntry.status)} Practice
              </a>
            </div>
          </section>
        ) : (
          <section class="begin-today">
            <h2>Cycle Complete</h2>
            <p>All 7 planetary entries for this cycle have been completed.</p>
            <div class="begin-actions">
              <a href={`/history/week/${activeCycle.cycle_id}`} class="btn btn-primary">View Cycle</a>
              <a href="/practice/new-week" class="btn">Begin New Cycle</a>
            </div>
          </section>
        )}
      </>
    )}
  </div>
</Layout>

<style>
  .spread-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-lg);
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .week-progress {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .progress-text {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .progress-bar {
    width: 120px;
    height: 6px;
    background: var(--color-bg-elevated);
    border-radius: 3px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-gold);
    transition: width 0.3s ease;
  }

  /* Card spread */
  .planetary-spread {
    margin-bottom: var(--space-xl);
  }

  .card-row {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: var(--space-sm);
  }

  .spread-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-md);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    transition: all 0.2s ease;
  }

  .spread-card.is-today {
    border-color: var(--color-gold);
    box-shadow: 0 0 12px rgba(201, 162, 39, 0.2);
  }

  .spread-card.status-card-complete {
    opacity: 0.6;
  }

  .spread-card .card-day {
    font-family: var(--font-display);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-dim);
  }

  .spread-card .card-name {
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .spread-card .card-status-icon {
    font-size: 0.75rem;
    color: var(--color-accent-body);
  }

  /* Today's practice */
  .today-practice {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-xl);
  }

  .today-cards {
    margin-bottom: var(--space-xl);
  }

  .planetary-focus {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .planetary-focus .label {
    font-family: var(--font-display);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-dim);
  }

  .planetary-focus .value {
    font-size: 1.25rem;
    color: var(--color-gold);
  }

  /* Status badge */
  .status-badge {
    font-size: 0.75rem;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-bg);
    color: var(--color-text-muted);
  }

  .status-active,
  .status-available {
    background: rgba(201, 162, 39, 0.2);
    color: var(--color-gold);
  }

  .status-complete {
    background: rgba(124, 152, 133, 0.2);
    color: var(--color-accent-body);
  }

  .status-integrating {
    background: rgba(100, 120, 200, 0.2);
    color: #8899dd;
  }

  /* Actions */
  .practice-actions {
    display: flex;
    gap: var(--space-md);
  }

  /* Begin today / cycle complete section */
  .begin-today {
    text-align: center;
    padding: var(--space-2xl);
    background: var(--color-bg-elevated);
    border: 1px dashed var(--color-border);
    border-radius: var(--card-radius);
  }

  .begin-today p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .begin-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
  }

  /* Error/empty states */
  .error-state,
  .empty-state {
    text-align: center;
    padding: var(--space-2xl);
  }

  .error-state .hint {
    color: var(--color-text-dim);
    font-size: 0.9rem;
  }

  .empty-icon {
    font-size: 2rem;
    margin-bottom: var(--space-md);
    color: var(--color-gold);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .card-row {
      grid-template-columns: repeat(4, 1fr);
    }

    .spread-card {
      padding: var(--space-sm);
    }

    .spread-card .card-name {
      font-size: 0.8rem;
    }
  }

  @media (max-width: 480px) {
    .card-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
