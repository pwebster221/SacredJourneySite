---
/**
 * Entry Detail Page
 *
 * Shows a single progression entry: planetary card, domain cards,
 * interpretation statuses, and action links.
 *
 * The [date] param now receives an entry_id UUID (V2).
 * File name kept as [date].astro for route compatibility.
 */
import Layout from '../../layouts/Layout.astro';
import { sacredJourney } from '../../lib/sacred-journey';
import type {
  ProgressionEntryResponse,
  EntryContextResponse,
  AllInterpretationsStatusResponse,
} from '../../lib/sacred-journey';
import { DOMAINS } from '../../lib/domain-utils';

const { date: entryId } = Astro.params;

// Validate that the param looks like a UUID
const uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
if (!entryId || !uuidRegex.test(entryId)) {
  return Astro.redirect('/');
}

let entry: ProgressionEntryResponse | null = null;
let context: EntryContextResponse | null = null;
let interps: AllInterpretationsStatusResponse | null = null;
let error: string | null = null;

try {
  entry = await sacredJourney.getEntry(entryId);
  context = await sacredJourney.getEntryContext(entryId);
  interps = await sacredJourney.getInterpretationsStatus(entryId);
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load entry';
}

// Derive display values
const planetName = entry?.planet ?? '';
const sequence = entry?.sequence ?? 0;
const entryStatus = entry?.status ?? 'available';
const planetaryCard = entry?.planetary_card ?? '';
const domainCards = entry?.domain_cards ?? {};
const cycleId = entry?.cycle_id ?? context?.cycle_id ?? '';
const allComplete = interps?.all_complete ?? false;
const completionCount = interps?.completion_count ?? 0;
const interpretations = interps?.interpretations ?? [];
const previousSynthesis = context?.previous_entry?.synthesis ?? null;
const samePlanetSynthesis = context?.same_planet_previous_cycle?.synthesis ?? null;

// Status label mapping
function statusLabel(status: string): string {
  switch (status) {
    case 'pending': return 'pending';
    case 'responded': return 'responded';
    case 'evaluated': return 'evaluated';
    case 'complete': return 'complete';
    default: return status;
  }
}

// Entry status badge
function entryStatusLabel(status: string): string {
  switch (status) {
    case 'available': return 'Available';
    case 'active': return 'Active';
    case 'integrating': return 'Integrating';
    case 'complete': return 'Complete';
    default: return status;
  }
}
---

<Layout title={`${planetName || 'Entry'} — Entry ${sequence} — Paths of Reverence`}>
  <div class="entry-detail-page">
    <header class="page-header">
      {cycleId ? (
        <a href={`/practice/cycle/${cycleId}`} class="back-link">&larr; Back to Cycle</a>
      ) : (
        <a href="/" class="back-link">&larr; Home</a>
      )}
      <h1>{planetName} &mdash; Entry {sequence} of 7</h1>
      <div class="header-meta">
        <span class={`entry-status-badge status-${entryStatus}`}>{entryStatusLabel(entryStatus)}</span>
        {planetaryCard && (
          <span class="planetary-card-name">{planetaryCard}</span>
        )}
      </div>
    </header>

    {error ? (
      <div class="error-state">
        <h2>Unable to Load</h2>
        <p>{error}</p>
        <a href="/" class="btn">Home</a>
      </div>
    ) : !entry ? (
      <div class="error-state">
        <h2>Entry Not Found</h2>
        <p>This entry could not be found.</p>
        <a href="/" class="btn">Home</a>
      </div>
    ) : (
      <div class="entry-content">
        {/* Planetary card highlight */}
        {planetaryCard && (
          <section class="cards-section">
            <div class="planetary-focus">
              <span class="label">Planetary Card</span>
              <span class="card-name">{planetaryCard}</span>
            </div>
          </section>
        )}

        {/* Domain cards */}
        {Object.keys(domainCards).length > 0 && (
          <section class="cards-section">
            <div class="domain-cards">
              {DOMAINS.map((domain) => (
                domainCards[domain] ? (
                  <div class={`domain-card domain-${domain.toLowerCase()}`}>
                    <span class="domain-label">{domain}</span>
                    <span class="card-name">{domainCards[domain]}</span>
                  </div>
                ) : null
              ))}
            </div>
          </section>
        )}

        {/* Previous entry synthesis */}
        {previousSynthesis && (
          <section class="context-section">
            <h2>Previous Entry Synthesis</h2>
            <blockquote class="synthesis-quote">{previousSynthesis}</blockquote>
          </section>
        )}

        {/* Same planet previous cycle synthesis */}
        {samePlanetSynthesis && (
          <section class="context-section">
            <h2>Same Planet — Previous Cycle</h2>
            <blockquote class="synthesis-quote">{samePlanetSynthesis}</blockquote>
          </section>
        )}

        {/* Interpretations section */}
        <section class="interpretations-section">
          <h2>Interpretations</h2>
          <p class="completion-summary">{completionCount} of {interpretations.length} complete</p>

          {allComplete ? (
            <div class="completed-badge">
              <span class="checkmark">&#10003;</span>
              <span>All {interpretations.length} domain interpretations complete</span>
            </div>
          ) : interpretations.length === 0 ? (
            <div class="pending-state">
              <div class="pending-icon">&#9675;</div>
              <h3>No Interpretations Yet</h3>
              <p>This entry's interpretations have not been started.</p>
              <div class="action-links">
                <a href={`/practice/session/${entryId}`} class="btn btn-primary">Start Chat Session</a>
                <a href={`/practice/prepare/${entryId}`} class="btn">Manual Preparation</a>
              </div>
            </div>
          ) : (
            <div class="interpretations-grid">
              {interpretations.map((interp) => {
                const statusClass = `status-${interp.status}`;
                return (
                  <div class={`interpretation-card domain-${interp.domain.toLowerCase()} ${statusClass}`}>
                    <div class="interp-header">
                      <span class="domain-name">{interp.domain}</span>
                      <span class={`status-badge ${statusClass}`}>{statusLabel(interp.status)}</span>
                    </div>
                    <div class="interp-content">
                      {interp.status === 'pending' && (
                        <p class="awaiting">Awaiting preparation...</p>
                      )}
                      {interp.status === 'responded' && (
                        <p class="awaiting">Awaiting evaluation...</p>
                      )}
                      {interp.status === 'evaluated' && (
                        <p class="awaiting">Evaluated — awaiting completion</p>
                      )}
                      {interp.status === 'complete' && (
                        <div class="complete-indicator">
                          <span class="checkmark">&#10003;</span>
                          <span>Complete</span>
                        </div>
                      )}
                    </div>
                    {interp.status === 'pending' && (
                      <a href={`/practice/prepare/${entryId}`} class="btn btn-sm">Prepare</a>
                    )}
                    {interp.status === 'responded' && (
                      <a href={`/practice/respond/${interp.interpretation_id}?entry=${entryId}&domain=${interp.domain}`} class="btn btn-sm">View</a>
                    )}
                  </div>
                );
              })}
            </div>
          )}

          {/* Action links when there are pending interpretations */}
          {interpretations.length > 0 && !allComplete && (
            <div class="prepare-actions">
              <a href={`/practice/session/${entryId}`} class="btn btn-primary">Open Chat Session</a>
              <a href={`/practice/prepare/${entryId}`} class="btn">Manual Preparation</a>
            </div>
          )}
        </section>

        {/* Navigation */}
        <section class="entry-navigation">
          {allComplete && entryStatus === 'complete' ? (
            <div class="nav-status">
              <span class="status-complete">&#10022; Entry Complete &#10022;</span>
            </div>
          ) : entryStatus === 'integrating' ? (
            <div class="nav-status">
              <span class="status-integrating">Integration Phase</span>
            </div>
          ) : null}
          <div class="nav-actions">
            {cycleId && (
              <a href={`/practice/cycle/${cycleId}`} class="btn">Back to Cycle</a>
            )}
            <a href={`/practice/session/${entryId}`} class="btn btn-primary">
              {entryStatus === 'complete' ? 'Revisit Session' : 'Open Chat Session'}
            </a>
          </div>
        </section>
      </div>
    )}
  </div>
</Layout>

<style>
  .entry-detail-page {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
  }

  .page-header {
    margin-bottom: var(--space-2xl);
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .back-link:hover { color: var(--color-gold); }

  .header-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }

  .entry-status-badge {
    font-size: 0.75rem;
    padding: 3px 10px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-bg-elevated);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .entry-status-badge.status-available {
    background: rgba(201, 162, 39, 0.1);
    color: var(--color-gold-dim);
    border-color: var(--color-gold-dim);
  }

  .entry-status-badge.status-active {
    background: rgba(201, 162, 39, 0.2);
    color: var(--color-gold);
    border-color: var(--color-gold);
  }

  .entry-status-badge.status-integrating {
    background: rgba(138, 130, 180, 0.2);
    color: #a89fd4;
    border-color: #a89fd4;
  }

  .entry-status-badge.status-complete {
    background: rgba(124, 152, 133, 0.2);
    color: var(--color-accent-body);
    border-color: var(--color-accent-body);
  }

  .planetary-card-name {
    color: var(--color-gold);
    font-family: var(--font-display);
    font-size: 1rem;
  }

  /* Cards section */
  .cards-section {
    margin-bottom: var(--space-2xl);
  }

  .planetary-focus {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-gold);
    border-radius: var(--card-radius);
    padding: var(--space-lg);
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .planetary-focus .label {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-dim);
    margin-bottom: var(--space-xs);
  }

  .planetary-focus .card-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-gold);
  }

  .domain-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  .domain-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-md);
    text-align: center;
    border-top: 3px solid var(--domain-color, var(--color-border));
  }

  .domain-card.domain-physical { --domain-color: var(--color-accent-body); }
  .domain-card.domain-emotional { --domain-color: var(--color-accent-heart); }
  .domain-card.domain-mental { --domain-color: var(--color-accent-mind); }
  .domain-card.domain-spiritual { --domain-color: var(--color-accent-spirit); }

  .domain-label {
    display: block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--domain-color);
    margin-bottom: var(--space-xs);
  }

  .domain-card .card-name {
    font-size: 0.9rem;
    color: var(--color-text);
  }

  /* Context section */
  .context-section {
    margin-bottom: var(--space-2xl);
  }

  .context-section h2 {
    font-size: 1rem;
    margin-bottom: var(--space-md);
  }

  .synthesis-quote {
    margin: 0;
    padding: var(--space-lg);
    background: var(--color-bg-elevated);
    border-left: 3px solid var(--color-gold-dim);
    border-radius: var(--card-radius);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-height: 300px;
    overflow-y: auto;
    white-space: pre-wrap;
  }

  /* Interpretations */
  .interpretations-section {
    margin-bottom: var(--space-2xl);
  }

  .interpretations-section h2 {
    margin-bottom: var(--space-sm);
  }

  .completion-summary {
    color: var(--color-text-dim);
    font-size: 0.9rem;
    margin-bottom: var(--space-lg);
  }

  .interpretations-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .interpretation-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-md);
    border-left: 4px solid var(--domain-color, var(--color-border));
  }

  .interpretation-card.domain-physical { --domain-color: var(--color-accent-body); }
  .interpretation-card.domain-emotional { --domain-color: var(--color-accent-heart); }
  .interpretation-card.domain-mental { --domain-color: var(--color-accent-mind); }
  .interpretation-card.domain-spiritual { --domain-color: var(--color-accent-spirit); }

  .interp-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-sm);
  }

  .domain-name {
    font-family: var(--font-display);
    color: var(--domain-color);
  }

  .status-badge {
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    background: var(--color-bg);
    color: var(--color-text-muted);
  }

  .status-badge.status-pending {
    background: rgba(201, 162, 39, 0.1);
    color: var(--color-gold-dim);
  }

  .status-badge.status-responded {
    background: rgba(201, 162, 39, 0.2);
    color: var(--color-gold);
  }

  .status-badge.status-evaluated {
    background: rgba(138, 130, 180, 0.2);
    color: #a89fd4;
  }

  .status-badge.status-complete {
    background: rgba(124, 152, 133, 0.2);
    color: var(--color-accent-body);
  }

  .interp-content .awaiting {
    color: var(--color-text-dim);
    font-size: 0.9rem;
    margin: 0;
  }

  .interp-content .complete-indicator {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-accent-body);
  }

  .checkmark { font-size: 1.2rem; }

  .btn-sm {
    font-size: 0.8rem;
    padding: 4px 12px;
    margin-top: var(--space-sm);
    display: inline-block;
  }

  .completed-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: rgba(124, 152, 133, 0.1);
    border: 1px solid var(--color-accent-body);
    border-radius: var(--card-radius);
    color: var(--color-accent-body);
  }

  .completed-badge .checkmark {
    font-size: 1.5rem;
  }

  /* Pending state */
  .pending-state {
    text-align: center;
    padding: var(--space-xl);
    background: var(--color-bg-card);
    border: 1px dashed var(--color-gold-dim);
    border-radius: var(--card-radius);
  }

  .pending-icon {
    font-size: 3rem;
    margin-bottom: var(--space-md);
    color: var(--color-gold-dim);
  }

  .pending-state h3 {
    color: var(--color-gold);
    margin-bottom: var(--space-sm);
  }

  .pending-state p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  /* Action links */
  .action-links, .prepare-actions {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  /* Entry navigation */
  .entry-navigation {
    margin-top: var(--space-2xl);
    padding: var(--space-xl);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    text-align: center;
  }

  .nav-status {
    margin-bottom: var(--space-lg);
  }

  .nav-status .status-complete {
    font-family: var(--font-display);
    color: var(--color-accent-body);
    letter-spacing: 0.1em;
  }

  .nav-status .status-integrating {
    font-family: var(--font-display);
    color: #a89fd4;
    letter-spacing: 0.1em;
  }

  .nav-actions {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
  }

  /* States */
  .error-state {
    text-align: center;
    padding: var(--space-2xl);
    background: var(--color-bg-elevated);
    border: 1px dashed var(--color-border);
    border-radius: var(--card-radius);
  }

  /* Loading overlay (kept for potential future use) */
  .loading-overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 10, 15, 0.9);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 100;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-gold);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: var(--space-md);
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  @media (max-width: 768px) {
    .domain-cards {
      grid-template-columns: repeat(2, 1fr);
    }

    .interpretations-grid {
      grid-template-columns: 1fr;
    }

    .header-meta {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
