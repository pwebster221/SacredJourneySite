---
/**
 * Daily Practice Page
 * 
 * Shows the day's spread and interpretation status.
 * Works for both current week entries AND archived week entries.
 * Fetches entry data client-side to handle all cases.
 */
import Layout from '../../layouts/Layout.astro';
import { sacredJourney } from '../../lib/sacred-journey';

const { date } = Astro.params;

// Validate date format
const dateRegex = /^\d{4}-\d{2}-\d{2}$/;
if (!date || !dateRegex.test(date)) {
  return Astro.redirect('/');
}

let context = null;
let error = null;
let weeklyReading = null;
let canBeginEntry = false;

// Try to get interpretation context for this date (works for any week)
try {
  context = await sacredJourney.getInterpretationContext(date);
} catch (e) {
  const msg = e instanceof Error ? e.message : '';
  // 404 means no entry yet - check if date is within a weekly reading
  if (msg.includes('404') || msg.includes('No daily entry')) {
    // Calculate the Sunday that starts this date's week
    const dateObj = new Date(date + 'T12:00:00');
    const dayOfWeek = dateObj.getDay(); // 0 = Sunday
    const weekStart = new Date(dateObj);
    weekStart.setDate(dateObj.getDate() - dayOfWeek);
    const weekStartStr = weekStart.toISOString().split('T')[0];
    
    // Check if a weekly reading exists for this week
    try {
      weeklyReading = await sacredJourney.getWeeklyProgress(weekStartStr);
      canBeginEntry = true; // Week exists, can begin entry
    } catch (weekErr) {
      // No weekly reading exists for this date
      canBeginEntry = false;
    }
  } else {
    error = msg || 'Failed to load interpretation context';
  }
}

// Parse date string as local date (avoid timezone issues)
const parseLocalDate = (dateStr: string) => {
  const [year, month, day] = dateStr.split('-').map(Number);
  return new Date(year, month - 1, day);
};

const formatDate = (dateStr: string) => {
  return parseLocalDate(dateStr).toLocaleDateString('en-US', {
    weekday: 'long',
    month: 'long',
    day: 'numeric',
  });
};

// Check if entry exists (context has entry_id means entry was created)
const entryExists = context && context.entry_id;

// Get the planetary card for this date from the weekly reading if available
const getDayPlanetaryCard = () => {
  if (!weeklyReading) return null;
  const dateObj = new Date(date + 'T12:00:00');
  const dayName = dateObj.toLocaleDateString('en-US', { weekday: 'long' });
  // WeeklyReading doesn't include planetary_cards in progress endpoint
  // We'd need to fetch the full reading, but for now just show the day
  return null;
};
---

<Layout title={`Practice - ${formatDate(date)} - Paths of Reverence`}>
  <div class="daily-practice-page" data-date={date} data-entry-exists={entryExists ? 'true' : 'false'}>
    <header class="page-header">
      <a href="/history" class="back-link">← Back to Archive</a>
      <h1>{formatDate(date)}</h1>
      {context?.planetary_ruler && (
        <p class="planetary-ruler">Planetary Card: {context.planetary_ruler}</p>
      )}
    </header>
    
    {error ? (
      <div class="error-state">
        <h2>Unable to Load</h2>
        <p>{error}</p>
        <a href="/history" class="btn">Back to Archive</a>
      </div>
    ) : entryExists ? (
      <!-- Entry exists - show interpretations (loaded client-side) -->
      <div class="entry-content" id="entry-content">
        <div class="loading-inline">
          <div class="spinner-small"></div>
          <span>Loading interpretations...</span>
        </div>
      </div>
    ) : (context || canBeginEntry) ? (
      <!-- Context exists OR week exists - show preview and begin button -->
      <div class="begin-entry-state">
        {context && Object.keys(context.domain_cards || {}).length > 0 && (
          <section class="cards-preview">
            <h2>Domain Cards for This Day</h2>
            <div class="domain-cards">
              {Object.entries(context.domain_cards).map(([domain, card]) => (
                <div class={`domain-card domain-${domain.toLowerCase()}`}>
                  <span class="domain-label">{domain}</span>
                  <span class="card-name">{card}</span>
                </div>
              ))}
            </div>
          </section>
        )}
        
        {context?.yesterday_synthesis && (
          <section class="context-section">
            <h2>Yesterday's Synthesis</h2>
            <blockquote class="yesterday-synthesis">{context.yesterday_synthesis}</blockquote>
          </section>
        )}
        
        {weeklyReading && (
          <section class="week-info">
            <p class="week-progress">Week Progress: {weeklyReading.days_complete}/7 days complete</p>
          </section>
        )}
        
        <div class="begin-prompt">
          <p>Ready to begin this day's practice?</p>
          <button class="btn btn-primary" id="begin-entry-btn">Begin Daily Entry</button>
        </div>

        <div class="session-prompt" style="margin-top: var(--space-lg); text-align: center;">
          <p class="hint">Or start a conversational exploration:</p>
          <a href={`/practice/session/${date}`} class="btn">Open Chat Session</a>
        </div>
      </div>
    ) : (
      <!-- No context at all - date has no associated weekly reading -->
      <div class="no-entry-state">
        <h2>No Reading Found</h2>
        <p>This date doesn't have an associated weekly reading.</p>
        <div class="action-links">
          <a href="/history" class="btn">View Archive</a>
          <a href="/practice/new-week" class="btn btn-primary">Begin New Week</a>
        </div>
      </div>
    )}
    
    <div class="loading-overlay" id="loading" style="display: none;">
      <div class="spinner"></div>
      <p id="loading-text">Creating daily entry...</p>
    </div>
  </div>
</Layout>

<script>
  // Use internal Tailscale URL for local dev, Funnel URL for production
  const isLocalDev = window.location.hostname === 'localhost' || window.location.hostname.startsWith('100.');
  const API_BASE = isLocalDev 
    ? 'http://100.117.79.64:8000' 
    : 'https://neo4jmiddleware.robin-alligator.ts.net';
  
  const page = document.querySelector('.daily-practice-page') as HTMLElement;
  const date = page?.dataset.date;
  const entryExists = page?.dataset.entryExists === 'true';
  const beginBtn = document.getElementById('begin-entry-btn');
  const loadingEl = document.getElementById('loading');
  const loadingText = document.getElementById('loading-text');
  const entryContent = document.getElementById('entry-content');

  // If entry exists, load interpretations client-side
  if (entryExists && entryContent) {
    loadInterpretations();
  }

  async function loadInterpretations() {
    console.log('[Sacred Journey] Loading interpretations for date:', date);
    
    try {
      // First try to get from current spread (works if this is today's entry)
      let interpretations = null;
      let domainCards = null;
      let planetaryCard = null;
      let synthesis = null;

      try {
        console.log('[Sacred Journey] Fetching current spread...');
        const spreadRes = await fetch(`${API_BASE}/sacred-journey/current-spread`);
        console.log('[Sacred Journey] Current spread response:', spreadRes.status);
        if (spreadRes.ok) {
          const spread = await spreadRes.json();
          console.log('[Sacred Journey] Current spread data:', spread);
          if (spread.today?.date === date) {
            console.log('[Sacred Journey] Found today in current spread');
            interpretations = spread.today.interpretations;
            domainCards = spread.today.domain_cards;
            planetaryCard = spread.today.planetary_card;
            synthesis = spread.today.synthesis;
          }
        }
      } catch (e) {
        console.log('[Sacred Journey] Current spread error:', e);
        // Current spread not available, try pending interpretations
      }

      // If not in current spread, fetch pending interpretations for this date
      if (!interpretations) {
        console.log('[Sacred Journey] Fetching pending interpretations...');
        const pendingRes = await fetch(`${API_BASE}/sacred-journey/interpretation/pending`);
        console.log('[Sacred Journey] Pending response:', pendingRes.status);
        if (pendingRes.ok) {
          const pendingData = await pendingRes.json();
          console.log('[Sacred Journey] Pending data:', pendingData);
          // Filter to just this date
          const dateInterps = (pendingData.pending || []).filter(
            (i: any) => i.date === date
          );
          console.log('[Sacred Journey] Filtered for date:', dateInterps);
          
          if (dateInterps.length > 0) {
            interpretations = dateInterps.map((i: any) => ({
              interpretation_id: i.interpretation_id,
              domain: i.domain,
              status: 'ready',
              introspection_question: i.introspection_question,
            }));
          }
        }
        
        // Get domain cards from context
        console.log('[Sacred Journey] Fetching context...');
        const contextRes = await fetch(`${API_BASE}/sacred-journey/daily/${date}/context`);
        console.log('[Sacred Journey] Context response:', contextRes.status);
        if (contextRes.ok) {
          const contextData = await contextRes.json();
          console.log('[Sacred Journey] Context data:', contextData);
          domainCards = contextData.domain_cards;
          planetaryCard = contextData.planetary_ruler;
        }
        
        // Try to get synthesis from history if we don't have it yet
        if (!synthesis) {
          console.log('[Sacred Journey] Fetching history for synthesis...');
          const historyRes = await fetch(`${API_BASE}/sacred-journey/history?limit=30&include_entries=true`);
          if (historyRes.ok) {
            const historyData = await historyRes.json();
            console.log('[Sacred Journey] History data received, entries:', historyData.recent_entries?.length);
            // Find the entry matching this date
            const matchingEntry = (historyData.recent_entries || []).find(
              (e: any) => e.date === date
            );
            if (matchingEntry) {
              console.log('[Sacred Journey] Found matching entry:', matchingEntry);
              synthesis = matchingEntry.synthesis;
              planetaryCard = planetaryCard || matchingEntry.planetary_card;
            }
          }
        }
      }
      
      console.log('[Sacred Journey] Final state:', { interpretations, domainCards, planetaryCard, synthesis });

      // Render the content
      if (interpretations && interpretations.length > 0) {
        // Check if any are actionable (ready status with questions)
        const hasReady = interpretations.some((i: any) => i.status === 'ready' && i.introspection_question);
        const allPrepared = interpretations.every((i: any) => i.status === 'prepared');
        const allComplete = interpretations.every((i: any) => i.status === 'complete');
        
        if (allComplete && synthesis) {
          // Truly complete - has synthesis and all interpretations done
          renderCompletedEntry(planetaryCard, domainCards, synthesis);
        } else if (allPrepared) {
          // All still in prepared state - need AI generation
          renderPreparedState(planetaryCard, domainCards, interpretations);
        } else {
          renderEntry(planetaryCard, domainCards, interpretations, synthesis);
        }
      } else if (synthesis) {
        // Entry has synthesis - it's complete
        renderCompletedEntry(planetaryCard, domainCards, synthesis);
      } else if (planetaryCard) {
        // Entry exists (has planetary card) but no interpretations found via API
        // This means interpretations are in 'prepared' status (not yet ready)
        renderPreparedState(planetaryCard, domainCards, []);
      } else {
        // Entry exists but no interpretations yet - show message
        entryContent!.innerHTML = `
          <div class="info-state">
            <h2>Entry Created</h2>
            <p>This day's entry has been created. Interpretations may need to be prepared.</p>
            <p class="hint">Check the Practice queue for pending items.</p>
            <a href="/practice/pending" class="btn btn-primary">View Practice Queue</a>
          </div>
        `;
      }

    } catch (err) {
      entryContent!.innerHTML = `
        <div class="error-state">
          <h2>Error Loading</h2>
          <p>${err instanceof Error ? err.message : 'Failed to load entry data'}</p>
          <button class="btn" onclick="window.location.reload()">Try Again</button>
        </div>
      `;
    }
  }

  function renderCompletedEntry(planetaryCard: string | null, domainCards: Record<string, string> | null, synthesis: string | null) {
    const domains = ['Body', 'Mind', 'Heart', 'Spirit'];
    let html = '';
    
    // Cards section
    if (planetaryCard) {
      html += `
        <section class="cards-section">
          <div class="planetary-focus">
            <span class="label">Planetary Card</span>
            <span class="card-name">${planetaryCard}</span>
          </div>
        </section>
      `;
    }
    
    if (domainCards && Object.keys(domainCards).length > 0) {
      html += '<section class="cards-section"><div class="domain-cards">';
      for (const domain of domains) {
        if (domainCards[domain]) {
          html += `
            <div class="domain-card domain-${domain.toLowerCase()}">
              <span class="domain-label">${domain}</span>
              <span class="card-name">${domainCards[domain]}</span>
            </div>
          `;
        }
      }
      html += '</div></section>';
    }
    
    // Completed interpretations indicator
    html += `
      <section class="interpretations-section">
        <h2>Interpretations</h2>
        <div class="completed-badge">
          <span class="checkmark">✓</span>
          <span>All 4 domain interpretations complete</span>
        </div>
      </section>
    `;
    
    // Synthesis section
    if (synthesis) {
      html += `
        <section class="synthesis-section">
          <h2>Daily Synthesis</h2>
          <div class="synthesis-content">${synthesis}</div>
        </section>
      `;
    }
    
    // Calculate next day's date
    const currentDate = new Date(date + 'T12:00:00'); // noon to avoid timezone issues
    const nextDate = new Date(currentDate);
    nextDate.setDate(nextDate.getDate() + 1);
    const nextDateStr = nextDate.toISOString().split('T')[0];
    const nextDayName = nextDate.toLocaleDateString('en-US', { weekday: 'long' });

    // Add navigation
    html += `
      <section class="day-navigation">
        <div class="nav-status">
          <span class="status-complete">✦ Day Complete ✦</span>
        </div>
        <div class="nav-actions">
          <a href="/history" class="btn">Back to Archive</a>
          <a href="/practice/session/${nextDateStr}" class="btn btn-primary">Continue to ${nextDayName} →</a>
        </div>
        <div class="nav-secondary">
          <a href="/practice/session/${date}" class="revisit-link">Revisit this day's session</a>
        </div>
      </section>
    `;
    
    entryContent!.innerHTML = html;
  }

  function renderEntry(planetaryCard: string | null, domainCards: Record<string, string> | null, interpretations: any[], synthesis: string | null) {
    const domains = ['Body', 'Mind', 'Heart', 'Spirit'];
    
    let html = '';
    
    // Cards section
    if (planetaryCard || domainCards) {
      html += '<section class="cards-section">';
      
      if (planetaryCard) {
        html += `
          <div class="planetary-focus">
            <span class="label">Planetary Card</span>
            <span class="card-name">${planetaryCard}</span>
          </div>
        `;
      }
      
      if (domainCards && Object.keys(domainCards).length > 0) {
        html += '<div class="domain-cards">';
        for (const domain of domains) {
          if (domainCards[domain]) {
            html += `
              <div class="domain-card domain-${domain.toLowerCase()}">
                <span class="domain-label">${domain}</span>
                <span class="card-name">${domainCards[domain]}</span>
              </div>
            `;
          }
        }
        html += '</div>';
      }
      
      html += '</section>';
    }
    
    // Interpretations section
    html += '<section class="interpretations-section"><h2>Interpretations</h2><div class="interpretations-grid">';
    
    for (const interp of interpretations) {
      const statusClass = `status-${interp.status}`;
      html += `
        <div class="interpretation-card domain-${interp.domain.toLowerCase()} ${statusClass}">
          <div class="interp-header">
            <span class="domain-name">${interp.domain}</span>
            <span class="status-badge ${statusClass}">${interp.status}</span>
          </div>
      `;
      
      if (interp.status === 'ready' && interp.introspection_question) {
        html += `
          <div class="interp-content">
            <p class="question">${interp.introspection_question}</p>
            <a href="/practice/respond/${interp.interpretation_id}" class="btn">Respond</a>
          </div>
        `;
      } else if (interp.status === 'responded') {
        html += '<div class="interp-content"><p class="awaiting">Awaiting evaluation...</p></div>';
      } else if (interp.status === 'complete') {
        html += '<div class="interp-content complete"><span class="checkmark">✓</span><span>Complete</span></div>';
      } else if (interp.status === 'prepared') {
        html += '<div class="interp-content"><p class="awaiting">Preparing interpretation...</p></div>';
      }
      
      html += '</div>';
    }
    
    html += '</div></section>';
    
    // Synthesis section
    if (synthesis) {
      html += `
        <section class="synthesis-section">
          <h2>Daily Synthesis</h2>
          <blockquote>${synthesis}</blockquote>
        </section>
      `;
    }
    
    entryContent!.innerHTML = html;
  }

  function renderPreparedState(planetaryCard: string | null, domainCards: Record<string, string> | null, interpretations: any[]) {
    const domains = ['Body', 'Mind', 'Heart', 'Spirit'];
    let html = '';
    
    // Cards section
    if (planetaryCard) {
      html += `
        <section class="cards-section">
          <div class="planetary-focus">
            <span class="label">Planetary Card</span>
            <span class="card-name">${planetaryCard}</span>
          </div>
        </section>
      `;
    }
    
    if (domainCards && Object.keys(domainCards).length > 0) {
      html += '<section class="cards-section"><div class="domain-cards">';
      for (const domain of domains) {
        if (domainCards[domain]) {
          html += `
            <div class="domain-card domain-${domain.toLowerCase()}">
              <span class="domain-label">${domain}</span>
              <span class="card-name">${domainCards[domain]}</span>
            </div>
          `;
        }
      }
      html += '</div></section>';
    }
    
    // Interpretations awaiting preparation
    html += `
      <section class="interpretations-section">
        <h2>Interpretations</h2>
        <div class="prepared-state">
          <div class="prepared-icon">⏳</div>
          <h3>Awaiting Preparation</h3>
          <p>The four domain interpretations have been created and need introspection questions.</p>
          <p class="hint">Use a Claude conversation with the Sacred Journey prompt to generate interpretations, then prepare them via the API.</p>
        </div>
        
        <div class="interpretations-grid prepared-grid">
          ${domains.map((domain: string) => `
            <div class="interpretation-card domain-${domain.toLowerCase()} status-prepared">
              <div class="interp-header">
                <span class="domain-name">${domain}</span>
                <span class="status-badge status-prepared">needs prep</span>
              </div>
              <div class="interp-content">
                <p class="awaiting">No introspection question yet</p>
              </div>
            </div>
          `).join('')}
        </div>
        
        <div class="prepare-actions">
          <a href="/history" class="btn">Back to Archive</a>
          <a href="/practice/session/${date}" class="btn btn-primary">Start Chat Session</a>
          <a href="/practice/prepare/${date}" class="btn">Manual Preparation</a>
        </div>
      </section>
    `;
    
    entryContent!.innerHTML = html;
  }

  // Begin entry button handler
  beginBtn?.addEventListener('click', async () => {
    loadingEl!.style.display = 'flex';
    
    try {
      const response = await fetch(`${API_BASE}/sacred-journey/daily/begin`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ entry_date: date }),
      });
      
      const data = await response.json().catch(() => ({}));
      
      // "Already exists" means entry is there - reload to show it
      if (!response.ok) {
        if (data.detail?.includes('already exists')) {
          window.location.reload();
          return;
        }
        throw new Error(data.detail || `Failed to begin entry: ${response.status}`);
      }
      
      // Success - reload to show the new entry
      window.location.reload();
      
    } catch (err) {
      loadingEl!.style.display = 'none';
      alert(err instanceof Error ? err.message : 'Failed to begin daily entry');
    }
  });
</script>

<style>
  .daily-practice-page {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
  }
  
  .page-header {
    margin-bottom: var(--space-2xl);
  }
  
  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }
  
  .back-link:hover { color: var(--color-gold); }
  
  .planetary-ruler {
    color: var(--color-gold);
    font-family: var(--font-display);
    margin: 0;
  }
  
  /* Loading inline */
  .loading-inline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    padding: var(--space-2xl);
    color: var(--color-text-muted);
  }
  
  .spinner-small {
    width: 24px;
    height: 24px;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-gold);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  
  /* Cards section */
  .cards-section, .cards-preview {
    margin-bottom: var(--space-2xl);
  }
  
  .planetary-focus {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-gold);
    border-radius: var(--card-radius);
    padding: var(--space-lg);
    text-align: center;
    margin-bottom: var(--space-lg);
  }
  
  .planetary-focus .label {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-dim);
    margin-bottom: var(--space-xs);
  }
  
  .planetary-focus .card-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-gold);
  }
  
  .domain-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }
  
  .domain-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-md);
    text-align: center;
    border-top: 3px solid var(--domain-color, var(--color-border));
  }
  
  .domain-card.domain-body { --domain-color: var(--color-accent-body); }
  .domain-card.domain-mind { --domain-color: var(--color-accent-mind); }
  .domain-card.domain-heart { --domain-color: var(--color-accent-heart); }
  .domain-card.domain-spirit { --domain-color: var(--color-accent-spirit); }
  
  .domain-label {
    display: block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--domain-color);
    margin-bottom: var(--space-xs);
  }
  
  .domain-card .card-name {
    font-size: 0.9rem;
    color: var(--color-text);
  }
  
  /* Context section */
  .context-section {
    margin-bottom: var(--space-2xl);
  }
  
  .context-section h2 {
    font-size: 1rem;
    margin-bottom: var(--space-md);
  }
  
  .yesterday-synthesis {
    margin: 0;
    padding: var(--space-lg);
    background: var(--color-bg-elevated);
    border-left: 3px solid var(--color-gold-dim);
    border-radius: var(--card-radius);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-height: 300px;
    overflow-y: auto;
    white-space: pre-wrap;
  }
  
  /* Interpretations */
  .interpretations-section h2 {
    margin-bottom: var(--space-lg);
  }
  
  .interpretations-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }
  
  .interpretation-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-md);
    border-left: 4px solid var(--domain-color, var(--color-border));
  }
  
  .interpretation-card.domain-body { --domain-color: var(--color-accent-body); }
  .interpretation-card.domain-mind { --domain-color: var(--color-accent-mind); }
  .interpretation-card.domain-heart { --domain-color: var(--color-accent-heart); }
