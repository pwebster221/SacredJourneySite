---
/**
 * Cycle Progress — shows all 7 planetary entries for a reading cycle
 */
import Layout from '../../../layouts/Layout.astro';
import { sacredJourney } from '../../../lib/sacred-journey';

const { cycle_id } = Astro.params;

let progress = null;
let error = null;

// Handle POST for "begin entry" action before loading data
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const entryId = formData.get('entry_id') as string;
  try {
    await sacredJourney.beginEntry(entryId);
    return Astro.redirect(`/practice/${entryId}`);
  } catch (e) {
    error = e instanceof Error ? e.message : 'Failed to begin entry';
  }
}

try {
  progress = await sacredJourney.getCycleProgress(cycle_id!);
} catch (e) {
  error = error || (e instanceof Error ? e.message : 'Failed to load cycle progress');
}

// Planet metadata for display
const PLANET_INFO: Record<string, { symbol: string; theme: string }> = {
  Sun:     { symbol: '☉', theme: 'Identity, vitality, core self' },
  Moon:    { symbol: '☽', theme: 'Emotions, intuition, inner world' },
  Mars:    { symbol: '♂', theme: 'Action, drive, courage' },
  Mercury: { symbol: '☿', theme: 'Communication, intellect, learning' },
  Jupiter: { symbol: '♃', theme: 'Expansion, wisdom, abundance' },
  Venus:   { symbol: '♀', theme: 'Love, values, beauty' },
  Saturn:  { symbol: '♄', theme: 'Structure, discipline, mastery' },
};

function formatDate(isoString: string | null): string {
  if (!isoString) return '';
  const datePart = isoString.split('T')[0];
  const [year, month, day] = datePart.split('-').map(Number);
  return new Date(year, month - 1, day).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
  });
}
---

<Layout title="Cycle Progress - Paths of Reverence">
  <div class="cycle-page">
    {error ? (
      <div class="error-state">
        <h2>Error</h2>
        <p>{error}</p>
        <a href="/" class="btn">Return Home</a>
      </div>
    ) : progress ? (
      <>
        <header class="cycle-header">
          <h1>Cycle Progress</h1>
          <p class="cycle-meta">
            Started {formatDate(progress.created_at)}
            &mdash; {progress.entries.filter(e => e.status === 'complete').length}/7 complete
          </p>
        </header>

        <ol class="entry-list">
          {progress.entries.map((entry) => {
            const info = PLANET_INFO[entry.planet] ?? { symbol: '?', theme: '' };
            return (
              <li class={`entry-row status-${entry.status}`}>
                <div class="entry-planet">
                  <span class="planet-symbol">{info.symbol}</span>
                  <div class="planet-detail">
                    <strong>{entry.sequence}. {entry.planet}</strong>
                    <span class="planet-theme">{info.theme}</span>
                  </div>
                </div>

                <span class={`status-badge status-${entry.status}`}>{entry.status}</span>

                <div class="entry-action">
                  {entry.status === 'available' && (
                    <form method="POST">
                      <input type="hidden" name="entry_id" value={entry.entry_id} />
                      <button type="submit" class="btn btn-primary btn-sm">Begin</button>
                    </form>
                  )}
                  {entry.status === 'active' && (
                    <a href={`/practice/${entry.entry_id}`} class="btn btn-primary btn-sm">Continue</a>
                  )}
                  {entry.status === 'integrating' && (
                    <a href={`/practice/integrate/${entry.entry_id}`} class="btn btn-sm">Integrate</a>
                  )}
                  {entry.status === 'complete' && (
                    <span class="complete-date">{formatDate(entry.completed_at)}</span>
                  )}
                </div>
              </li>
            );
          })}
        </ol>
      </>
    ) : null}
  </div>
</Layout>

<style>
  .cycle-page {
    max-width: 700px;
    margin: 0 auto;
  }

  .cycle-header {
    margin-bottom: var(--space-xl, 2rem);
  }

  .cycle-header h1 {
    margin-bottom: var(--space-xs, 0.25rem);
  }

  .cycle-meta {
    color: var(--color-text-muted, #888);
    font-size: 0.9rem;
  }

  .entry-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md, 1rem);
  }

  .entry-row {
    display: flex;
    align-items: center;
    gap: var(--space-md, 1rem);
    padding: var(--space-md, 1rem);
    border-radius: var(--card-radius, 8px);
    background: var(--color-bg-card, #1a1a2e);
    border: 1px solid var(--color-border, #2a2a4a);
  }

  .entry-row.status-complete {
    opacity: 0.7;
  }

  .entry-planet {
    display: flex;
    align-items: center;
    gap: var(--space-sm, 0.5rem);
    flex: 1;
  }

  .planet-symbol {
    font-size: 1.5rem;
    width: 2rem;
    text-align: center;
  }

  .planet-detail {
    display: flex;
    flex-direction: column;
  }

  .planet-theme {
    font-size: 0.8rem;
    color: var(--color-text-muted, #888);
  }

  .status-badge {
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  .status-badge.status-available {
    background: rgba(102, 204, 102, 0.15);
    color: #6c6;
  }
  .status-badge.status-active {
    background: rgba(201, 162, 39, 0.2);
    color: var(--color-gold, #cc6);
  }
  .status-badge.status-integrating {
    background: rgba(153, 153, 255, 0.15);
    color: #99f;
  }
  .status-badge.status-complete {
    background: rgba(124, 152, 133, 0.2);
    color: var(--color-accent-body, #484);
  }

  .entry-action {
    min-width: 100px;
    text-align: right;
  }

  .complete-date {
    font-size: 0.8rem;
    color: var(--color-text-muted, #888);
  }

  .btn-sm {
    padding: 0.3rem 0.8rem;
    font-size: 0.85rem;
  }

  .error-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-2xl);
    background: var(--color-bg-elevated);
    border: 1px dashed var(--color-border);
    border-radius: var(--card-radius);
  }

  @media (max-width: 600px) {
    .entry-row {
      flex-wrap: wrap;
    }

    .entry-planet {
      flex: 1 1 100%;
    }

    .status-badge {
      margin-left: 2.5rem;
    }

    .entry-action {
      margin-left: auto;
    }
  }
</style>
