---
/**
 * Begin New Cycle - Card Input
 *
 * Draw your 11 cards and begin a new reading cycle.
 * Planetary sequence: 7 planet cards (Sun, Moon, Mars, Mercury, Jupiter, Venus, Saturn)
 * Plus 4 domain cards (Physical, Emotional, Mental, Spiritual)
 */
import Layout from "../../layouts/Layout.astro";
import { sacredJourney } from "../../lib/sacred-journey";
import { TAROT_DECK } from "../../lib/tarot-data";

// Handle POST submission server-side
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData()

  const planetary_cards: Record<string, string> = {}
  for (const seq of ['1', '2', '3', '4', '5', '6', '7']) {
    planetary_cards[seq] = formData.get(`planet_${seq}`) as string
  }

  const domain_cards: Record<string, string> = {}
  for (const domain of ['Physical', 'Emotional', 'Mental', 'Spiritual']) {
    domain_cards[domain] = formData.get(`domain_${domain}`) as string
  }

  const cycle = await sacredJourney.createCycle({ planetary_cards, domain_cards })
  return Astro.redirect(`/practice/cycle/${cycle.cycle_id}`)
}

const planets = [
  { seq: "1", planet: "Sun", symbol: "☉" },
  { seq: "2", planet: "Moon", symbol: "☽" },
  { seq: "3", planet: "Mars", symbol: "♂" },
  { seq: "4", planet: "Mercury", symbol: "☿" },
  { seq: "5", planet: "Jupiter", symbol: "♃" },
  { seq: "6", planet: "Venus", symbol: "♀" },
  { seq: "7", planet: "Saturn", symbol: "♄" },
];

const domains = [
  { key: "Physical", element: "Earth", color: "physical" },
  { key: "Emotional", element: "Water", color: "emotional" },
  { key: "Mental", element: "Air", color: "mental" },
  { key: "Spiritual", element: "Fire", color: "spiritual" },
];
---

<Layout title="Begin New Cycle - Paths of Reverence">
  <div class="new-week-page">
    <header class="page-header">
      <h1>Begin New Cycle</h1>
      <p class="page-subtitle">Draw your 11 cards to open a new planetary reading cycle</p>
    </header>

    <form id="cycle-form" class="spread-form" method="POST">

      <section class="card-section">
        <h2>Planetary Sequence Cards</h2>
        <p class="section-desc">Draw one card for each planet in the sequence</p>

        <div class="planetary-grid">
          {
            planets.map((p) => (
              <div class="card-input-group">
                <label for={`planet-${p.seq}`}>
                  <span class="planet-symbol">{p.symbol}</span>
                  <span class="planet-name">{p.planet}</span>
                  <span class="seq-label">#{p.seq}</span>
                </label>
                <input
                  type="text"
                  id={`planet-${p.seq}`}
                  name={`planet_${p.seq}`}
                  placeholder="Card name..."
                  list="tarot-cards"
                  required
                  autocomplete="off"
                />
              </div>
            ))
          }
        </div>
      </section>

      <section class="card-section">
        <h2>Domain Cards</h2>
        <p class="section-desc">Draw one card for each domain of experience</p>

        <div class="domain-grid">
          {
            domains.map((domain) => (
              <div class={`card-input-group domain-${domain.color}`}>
                <label for={`domain-${domain.key}`}>
                  <span class="domain-name">{domain.key}</span>
                  <span class="element-name">{domain.element}</span>
                </label>
                <input
                  type="text"
                  id={`domain-${domain.key}`}
                  name={`domain_${domain.key}`}
                  placeholder="Card name..."
                  list="tarot-cards"
                  required
                  autocomplete="off"
                />
              </div>
            ))
          }
        </div>
      </section>

      <datalist id="tarot-cards">
        {TAROT_DECK.map((card) => <option value={card} />)}
      </datalist>

      <div class="form-actions">
        <a href="/" class="btn">Cancel</a>
        <button type="submit" class="btn btn-primary" id="submit-btn">
          Begin Cycle
        </button>
      </div>
    </form>

    <div class="error-state" id="error" style="display: none;">
      <h2>Something went wrong</h2>
      <p id="error-message"></p>
      <button
        class="btn"
        onclick="document.getElementById('error').style.display='none'; document.getElementById('cycle-form').style.display='block';"
      >
        Try Again
      </button>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById("cycle-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const errorEl = document.getElementById("error");
  const errorMsg = document.getElementById("error-message");

  form?.addEventListener("submit", () => {
    submitBtn.textContent = "Creating...";
    submitBtn.setAttribute("disabled", "true");
  });
</script>

<style>
  .new-week-page {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .page-subtitle {
    color: var(--color-text-muted);
    margin: var(--space-sm) 0 0;
    font-size: 1rem;
  }

  .card-section {
    margin-bottom: var(--space-2xl);
  }

  .card-section h2 {
    text-align: center;
    margin-bottom: var(--space-xs);
  }

  .section-desc {
    text-align: center;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .planetary-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: var(--space-sm);
  }

  .domain-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  .card-input-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .card-input-group label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    cursor: pointer;
  }

  .planet-symbol {
    font-size: 1.5rem;
    color: var(--color-gold);
  }

  .planet-name {
    font-family: var(--font-display);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text);
  }

  .seq-label {
    font-size: 0.7rem;
    color: var(--color-text-dim);
  }

  .domain-name {
    font-family: var(--font-display);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .element-name {
    font-size: 0.75rem;
    color: var(--color-text-dim);
  }

  /* Domain colors */
  .domain-physical .domain-name {
    color: var(--color-accent-body, var(--color-accent));
  }
  .domain-emotional .domain-name {
    color: var(--color-accent-heart, var(--color-accent));
  }
  .domain-mental .domain-name {
    color: var(--color-accent-mind, var(--color-accent));
  }
  .domain-spiritual .domain-name {
    color: var(--color-accent-spirit, var(--color-accent));
  }

  .card-input-group input {
    width: 100%;
    padding: var(--space-sm);
    font-family: var(--font-body);
    font-size: 0.85rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    color: var(--color-text);
    text-align: center;
  }

  .card-input-group input:focus {
    outline: none;
    border-color: var(--color-gold);
  }

  .card-input-group input::placeholder {
    color: var(--color-text-dim);
    font-size: 0.8rem;
  }

  .form-actions {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  .error-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-2xl);
  }

  @media (max-width: 768px) {
    .planetary-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .domain-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .planet-symbol {
      font-size: 1.2rem;
    }
  }

  @media (max-width: 480px) {
    .planetary-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
