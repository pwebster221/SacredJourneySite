---
/**
 * Pending Interpretations - Practice Queue
 *
 * Shows all interpretations awaiting user response.
 * V2: No dedicated /interpretation/pending endpoint exists.
 * We derive the list from active cycles -> progress -> interpretations status.
 */
import Layout from '../../layouts/Layout.astro';
import { sacredJourney } from '../../lib/sacred-journey';
import type { InterpretationStatusItem } from '../../lib/sacred-journey';

let pendingInterpretations: (InterpretationStatusItem & { entry_id: string; planet: string; sequence: number })[] = [];
let error = null;

try {
  const { active_cycles } = await sacredJourney.getActiveCycles();

  for (const cycle of active_cycles) {
    const progress = await sacredJourney.getCycleProgress(cycle.cycle_id);
    const activeEntry = progress.current_entry;
    if (activeEntry && activeEntry.status === 'active') {
      const status = await sacredJourney.getInterpretationsStatus(activeEntry.entry_id);
      for (const interp of status.interpretations) {
        if (interp.status === 'pending' || interp.status === 'responded') {
          pendingInterpretations.push({
            ...interp,
            entry_id: activeEntry.entry_id,
            planet: activeEntry.planet,
            sequence: activeEntry.sequence,
          });
        }
      }
    }
  }
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load pending interpretations';
}
---

<Layout title="Practice Queue - Paths of Reverence">
  <div class="pending-page">
    <header class="page-header">
      <h1>Practice Queue</h1>
      <p class="subtitle">Interpretations awaiting your reflection</p>
    </header>

    {error ? (
      <div class="error-state">
        <p>{error}</p>
      </div>
    ) : pendingInterpretations.length === 0 ? (
      <div class="empty-state">
        <div class="empty-icon">&#10022;</div>
        <h2>All Clear</h2>
        <p>No pending interpretations. Your practice is complete for now.</p>
        <a href="/" class="btn">Return Home</a>
      </div>
    ) : (
      <div class="pending-list">
        {pendingInterpretations.map((interp) => (
          <article class={`pending-card domain-${interp.domain.toLowerCase()}`}>
            <div class="card-header">
              <span class="domain-badge">{interp.domain}</span>
              <span class="status-badge" data-status={interp.status}>{interp.status}</span>
            </div>

            <div class="card-meta">
              <span class="planet-name">{interp.planet}</span>
              <span class="separator">&mdash;</span>
              <span class="sequence">Entry {interp.sequence} of 7</span>
            </div>

            <div class="card-actions">
              <a
                href={`/practice/respond/${interp.interpretation_id}?entry=${interp.entry_id}&domain=${interp.domain}`}
                class="btn btn-primary"
              >
                Reflect &amp; Respond
              </a>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</Layout>

<style>
  .pending-page {
    max-width: 800px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .subtitle {
    color: var(--color-text-muted);
    margin: 0;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-2xl);
    background: var(--color-bg-elevated);
    border: 1px dashed var(--color-border);
    border-radius: var(--card-radius);
  }

  .empty-icon {
    font-size: 3rem;
    color: var(--color-gold);
    margin-bottom: var(--space-md);
  }

  .empty-state h2 {
    margin-bottom: var(--space-sm);
  }

  .empty-state p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .pending-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .pending-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-lg);
    border-left: 4px solid var(--domain-color, var(--color-border));
  }

  .pending-card.domain-physical { --domain-color: var(--color-accent-body); }
  .pending-card.domain-emotional { --domain-color: var(--color-accent-heart); }
  .pending-card.domain-mental { --domain-color: var(--color-accent-mind); }
  .pending-card.domain-spiritual { --domain-color: var(--color-accent-spirit); }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-md);
  }

  .domain-badge {
    font-family: var(--font-display);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--domain-color);
  }

  .status-badge {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: var(--space-xs) var(--space-sm);
    border-radius: 4px;
    background: var(--color-bg-elevated);
    color: var(--color-text-muted);
  }

  .status-badge[data-status="pending"] {
    color: var(--color-gold);
  }

  .status-badge[data-status="responded"] {
    color: var(--color-accent-mind);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .planet-name {
    font-family: var(--font-display);
  }

  .separator {
    color: var(--color-text-dim);
  }

  .card-actions {
    display: flex;
    justify-content: flex-end;
  }

  .error-state {
    text-align: center;
    padding: var(--space-xl);
    color: var(--color-accent-heart);
  }

  @media (max-width: 600px) {
    .card-header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
    }

    .card-meta {
      flex-wrap: wrap;
    }
  }
</style>
