---
/**
 * Prepare Interpretations Page
 *
 * Server-side preparation of interpretation contexts for a progression entry.
 * In V2, each domain is prepared via POST /interpretations/{entry_id}/prepare
 * which returns the context needed for AI-assisted interpretation.
 *
 * The [date] param now receives an entry_id UUID (V2).
 * File name kept as [date].astro for route compatibility.
 */
import Layout from '../../../layouts/Layout.astro';
import { sacredJourney } from '../../../lib/sacred-journey';
import type {
  ProgressionEntryResponse,
  AllInterpretationsStatusResponse,
  Domain,
} from '../../../lib/sacred-journey';
import { DOMAINS } from '../../../lib/domain-utils';

const { date: entryId } = Astro.params;

// Validate that the param looks like a UUID
const uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
if (!entryId || !uuidRegex.test(entryId)) {
  return Astro.redirect('/');
}

// Handle POST — prepare interpretations for one or all domains
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const domain = formData.get('domain') as string;

    if (domain === 'all') {
      // Fetch current status to find pending domains
      const currentStatus = await sacredJourney.getInterpretationsStatus(entryId);
      for (const d of DOMAINS) {
        const existing = currentStatus.interpretations.find(i => i.domain === d);
        if (!existing || existing.status === 'pending') {
          await sacredJourney.prepareInterpretation(entryId, d as Domain);
        }
      }
    } else {
      await sacredJourney.prepareInterpretation(entryId, domain as Domain);
    }
  } catch (e) {
    // Redirect back with error handled below on re-fetch
    console.error('Prepare error:', e);
  }

  return Astro.redirect(`/practice/prepare/${entryId}`);
}

// GET — load entry and interpretation status
let entry: ProgressionEntryResponse | null = null;
let interps: AllInterpretationsStatusResponse | null = null;
let error: string | null = null;

try {
  entry = await sacredJourney.getEntry(entryId);
  interps = await sacredJourney.getInterpretationsStatus(entryId);
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load entry';
}

// Derive display values
const planetName = entry?.planet ?? '';
const sequence = entry?.sequence ?? 0;
const planetaryCard = entry?.planetary_card ?? '';
const domainCards = entry?.domain_cards ?? {};
const interpretations = interps?.interpretations ?? [];
const allComplete = interps?.all_complete ?? false;
const completionCount = interps?.completion_count ?? 0;

// Count domains that still need preparation (pending with no responded/evaluated/complete)
const pendingDomains = DOMAINS.filter(d => {
  const existing = interpretations.find(i => i.domain === d);
  return !existing || existing.status === 'pending';
});
const pendingCount = pendingDomains.length;
const allPrepared = pendingCount === 0;

// Status label for display
function statusLabel(status: string): string {
  switch (status) {
    case 'pending': return 'pending';
    case 'responded': return 'responded';
    case 'evaluated': return 'evaluated';
    case 'complete': return 'complete';
    default: return status;
  }
}
---

<Layout title={`Prepare Interpretations — ${planetName || 'Entry'} ${sequence} — Paths of Reverence`}>
  <div class="prepare-page">
    <header class="page-header">
      <a href={`/practice/${entryId}`} class="back-link">&larr; Back to Entry</a>
      <h1>Prepare Interpretations</h1>
      <div class="header-meta">
        <span class="planet-name">{planetName} — Entry {sequence} of 7</span>
        {planetaryCard && (
          <span class="planetary-card-name">{planetaryCard}</span>
        )}
      </div>
    </header>

    {error ? (
      <div class="error-state">
        <h2>Error Loading</h2>
        <p>{error}</p>
        <a href="/" class="btn">Home</a>
      </div>
    ) : !entry ? (
      <div class="error-state">
        <h2>Entry Not Found</h2>
        <p>This entry could not be found.</p>
        <a href={`/practice/${entryId}`} class="btn btn-primary">Back to Entry</a>
      </div>
    ) : allPrepared ? (
      <div class="all-ready-state">
        <h2>All Interpretations Prepared</h2>
        <p>All domain interpretations have been prepared and are ready for your responses.</p>
        <div class="status-grid">
          {interpretations.map((interp) => (
            <div class={`status-item domain-${interp.domain.toLowerCase()}`}>
              <span class="domain-label">{interp.domain}</span>
              <span class={`status-badge status-${interp.status}`}>{statusLabel(interp.status)}</span>
              {interp.status === 'pending' && interp.interpretation_id && (
                <a href={`/practice/respond/${interp.interpretation_id}`} class="btn btn-sm">Respond</a>
              )}
            </div>
          ))}
        </div>
        <div class="action-buttons">
          <a href={`/practice/${entryId}`} class="btn btn-primary">Back to Entry</a>
          <a href="/practice/pending" class="btn">View Pending Responses</a>
        </div>
      </div>
    ) : (
      <div class="preparation-content">
        <div class="action-bar">
          <div class="status-summary">
            <span class="needs-prep">{pendingCount} domain{pendingCount !== 1 ? 's' : ''} need{pendingCount === 1 ? 's' : ''} preparation</span>
            {completionCount > 0 && (
              <span class="completion-note">&nbsp;· {completionCount} complete</span>
            )}
          </div>
          <form method="POST">
            <input type="hidden" name="domain" value="all" />
            <button type="submit" class="btn btn-primary">
              Prepare All Domains
            </button>
          </form>
        </div>

        <div class="interpretations-list">
          {DOMAINS.map((domain) => {
            const interp = interpretations.find(i => i.domain === domain);
            const status = interp?.status ?? 'pending';
            const isPending = status === 'pending';
            const domainCard = domainCards[domain] || '';

            return (
              <div
                class={`interpretation-card domain-${domain.toLowerCase()} ${!isPending ? 'is-done' : ''}`}
                data-domain={domain}
              >
                <div class="card-header">
                  <div class="header-left">
                    <h3>{domain}</h3>
                    {domainCard && (
                      <span class="domain-card-name">{domainCard}</span>
                    )}
                  </div>
                  <span class={`status-badge status-${status}`}>
                    {statusLabel(status)}
                  </span>
                </div>

                <div class="card-body">
                  {isPending ? (
                    <div class="pending-content">
                      <p class="pending-text">
                        This domain interpretation has not been prepared yet.
                        Click "Prepare" to generate the interpretation context.
                      </p>
                      <div class="card-actions">
                        <form method="POST">
                          <input type="hidden" name="domain" value={domain} />
                          <button type="submit" class="btn btn-secondary">
                            Prepare {domain}
                          </button>
                        </form>
                      </div>
                    </div>
                  ) : (
                    <div class="done-content">
                      {status === 'responded' && (
                        <p class="status-text">Response submitted — awaiting evaluation.</p>
                      )}
                      {status === 'evaluated' && (
                        <p class="status-text">Evaluated — awaiting completion.</p>
                      )}
                      {status === 'complete' && (
                        <div class="complete-indicator">
                          <span class="checkmark">&#10003;</span>
                          <span>Complete</span>
                        </div>
                      )}
                      {status === 'pending' && interp?.interpretation_id && (
                        <div class="prepared-actions">
                          <a href={`/practice/respond/${interp.interpretation_id}`} class="btn btn-sm">
                            Respond to Interpretation
                          </a>
                        </div>
                      )}
                      {(status === 'responded' || status === 'evaluated') && interp?.interpretation_id && (
                        <div class="prepared-actions">
                          <a href={`/practice/respond/${interp.interpretation_id}`} class="btn btn-sm">
                            View Response
                          </a>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            );
          })}
        </div>

        <div class="page-actions">
          <a href={`/practice/${entryId}`} class="btn">Back to Entry</a>
          <a href={`/practice/session/${entryId}`} class="btn btn-primary">Open Chat Session</a>
        </div>
      </div>
    )}
  </div>
</Layout>

<style>
  .prepare-page {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: var(--space-xl);
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .back-link:hover {
    color: var(--color-gold);
  }

  .header-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }

  .planet-name {
    color: var(--color-text-muted);
  }

  .planetary-card-name {
    color: var(--color-gold);
    font-family: var(--font-display);
    font-size: 1rem;
  }

  /* Action bar */
  .action-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xl);
    padding: var(--space-md) var(--space-lg);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
  }

  .status-summary {
    color: var(--color-text-muted);
  }

  .needs-prep {
    color: var(--color-gold);
  }

  .completion-note {
    color: var(--color-text-dim);
  }

  /* Interpretation cards */
  .interpretations-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .interpretation-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    border-left: 4px solid var(--domain-color, var(--color-border));
    overflow: hidden;
  }

  .interpretation-card.domain-physical { --domain-color: var(--color-accent-body); }
  .interpretation-card.domain-emotional { --domain-color: var(--color-accent-heart); }
  .interpretation-card.domain-mental { --domain-color: var(--color-accent-mind); }
  .interpretation-card.domain-spiritual { --domain-color: var(--color-accent-spirit); }

  .interpretation-card.is-done {
    opacity: 0.7;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-md) var(--space-lg);
    background: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
  }

  .header-left {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
  }

  .card-header h3 {
    margin: 0;
    color: var(--domain-color);
    font-family: var(--font-display);
  }

  .domain-card-name {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .status-badge {
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    background: var(--color-bg);
    color: var(--color-text-muted);
  }

  .status-badge.status-pending {
    background: rgba(201, 162, 39, 0.1);
    color: var(--color-gold-dim);
  }

  .status-badge.status-responded {
    background: rgba(201, 162, 39, 0.2);
    color: var(--color-gold);
  }

  .status-badge.status-evaluated {
    background: rgba(138, 130, 180, 0.2);
    color: #a89fd4;
  }

  .status-badge.status-complete {
    background: rgba(124, 152, 133, 0.2);
    color: var(--color-accent-body);
  }

  .card-body {
    padding: var(--space-lg);
  }

  .pending-text {
    color: var(--color-text-dim);
    margin: 0 0 var(--space-md);
    line-height: 1.6;
  }

  .card-actions {
    display: flex;
    justify-content: flex-end;
  }

  .status-text {
    color: var(--color-text-dim);
    font-size: 0.9rem;
    margin: 0;
  }

  .complete-indicator {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-accent-body);
  }

  .checkmark {
    font-size: 1.2rem;
  }

  .prepared-actions {
    margin-top: var(--space-sm);
  }

  .btn-sm {
    font-size: 0.8rem;
    padding: 4px 12px;
    display: inline-block;
  }

  .btn-secondary {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .btn-secondary:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  /* Page actions */
  .page-actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-md);
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  /* States */
  .error-state,
  .all-ready-state {
    text-align: center;
    padding: var(--space-2xl);
    background: var(--color-bg-elevated);
    border: 1px dashed var(--color-border);
    border-radius: var(--card-radius);
  }

  .all-ready-state h2 {
    color: #22c55e;
  }

  .status-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    margin: var(--space-lg) 0;
  }

  .status-item {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-md);
    text-align: center;
    border-top: 3px solid var(--domain-color, var(--color-border));
  }

  .status-item.domain-physical { --domain-color: var(--color-accent-body); }
  .status-item.domain-emotional { --domain-color: var(--color-accent-heart); }
  .status-item.domain-mental { --domain-color: var(--color-accent-mind); }
  .status-item.domain-spiritual { --domain-color: var(--color-accent-spirit); }

  .status-item .domain-label {
    display: block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--domain-color);
    margin-bottom: var(--space-xs);
  }

  .action-buttons {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    margin-top: var(--space-lg);
  }

  @media (max-width: 768px) {
    .action-bar {
      flex-direction: column;
      gap: var(--space-md);
      text-align: center;
    }

    .page-actions {
      flex-direction: column;
    }

    .header-left {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }

    .status-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .header-meta {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
