---
/**
 * Prepare Interpretations Page
 *
 * AI-assisted preparation of interpretations for a daily entry.
 * Generates interpretation text and introspection questions for each domain.
 */
import Layout from '../../../layouts/Layout.astro';
import { sacredJourney } from '../../../lib/sacred-journey';
import type { DailyInterpretationsResponse } from '../../../lib/sacred-journey';

const { date } = Astro.params;

// Validate date format
const dateRegex = /^\d{4}-\d{2}-\d{2}$/;
if (!date || !dateRegex.test(date)) {
  return Astro.redirect('/');
}

let data: DailyInterpretationsResponse | null = null;
let error: string | null = null;

try {
  data = await sacredJourney.getDailyInterpretations(date);
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load interpretations';
}

// Parse date string as local date
const parseLocalDate = (dateStr: string) => {
  const [year, month, day] = dateStr.split('-').map(Number);
  return new Date(year, month - 1, day);
};

const formatDate = (dateStr: string) => {
  return parseLocalDate(dateStr).toLocaleDateString('en-US', {
    weekday: 'long',
    month: 'long',
    day: 'numeric',
  });
};

// Check if all interpretations are already prepared (ready or later status)
const allReady = data?.interpretations?.every(i => i.status !== 'prepared') ?? false;
const preparedCount = data?.interpretations?.filter(i => i.status === 'prepared').length ?? 0;
---

<Layout title={`Prepare Interpretations - ${formatDate(date)} - Paths of Reverence`}>
  <div class="prepare-page">
    <header class="page-header">
      <a href={`/practice/${date}`} class="back-link">← Back to {formatDate(date)}</a>
      <h1>Prepare Interpretations</h1>
      <p class="subtitle">{formatDate(date)}</p>
      {data?.planetary_card && (
        <p class="planetary-card">Planetary Card: <strong>{data.planetary_card}</strong></p>
      )}
    </header>

    {error ? (
      <div class="error-state">
        <h2>Error Loading</h2>
        <p>{error}</p>
        <a href="/history" class="btn">Back to Archive</a>
      </div>
    ) : !data?.entry_id ? (
      <div class="error-state">
        <h2>No Entry Found</h2>
        <p>This date doesn't have a daily entry yet.</p>
        <a href={`/practice/${date}`} class="btn btn-primary">Go to Practice Page</a>
      </div>
    ) : allReady ? (
      <div class="all-ready-state">
        <h2>All Interpretations Ready</h2>
        <p>All domain interpretations have already been prepared.</p>
        <div class="action-buttons">
          <a href={`/practice/${date}`} class="btn btn-primary">View Today's Practice</a>
          <a href="/practice/pending" class="btn">View Pending Responses</a>
        </div>
      </div>
    ) : (
      <div class="preparation-forms">
        <div class="action-bar">
          <div class="status-summary">
            <span class="needs-prep">{preparedCount} domain{preparedCount !== 1 ? 's' : ''} need{preparedCount === 1 ? 's' : ''} preparation</span>
          </div>
          <button type="button" class="btn btn-primary" id="generate-all-btn">
            <span class="btn-icon">✨</span>
            Generate All Interpretations
          </button>
        </div>

        <div class="interpretations-list" id="interpretations-list">
          {data.interpretations.map((interp) => {
            const domainCard = data.domain_cards?.[interp.domain] || 'Unknown';
            const isReady = interp.status !== 'prepared';

            return (
              <div
                class={`interpretation-form domain-${interp.domain.toLowerCase()} ${isReady ? 'is-ready' : ''}`}
                data-domain={interp.domain}
                data-interpretation-id={interp.interpretation_id}
                data-domain-card={domainCard}
                data-status={interp.status}
              >
                <div class="form-header">
                  <div class="header-left">
                    <h3>{interp.domain}</h3>
                    <span class="domain-card-name">{domainCard}</span>
                  </div>
                  <span class={`status-badge status-${interp.status}`}>
                    {interp.status === 'prepared' ? 'needs prep' : interp.status}
                  </span>
                </div>

                <div class="form-body">
                  {isReady ? (
                    <div class="ready-content">
                      <div class="field">
                        <label>Interpretation</label>
                        <div class="readonly-text">{interp.prepared_interpretation}</div>
                      </div>
                      <div class="field">
                        <label>Introspection Question</label>
                        <div class="readonly-text question">{interp.introspection_question}</div>
                      </div>
                    </div>
                  ) : (
                    <div class="editable-content">
                      <div class="field">
                        <label for={`interp-${interp.domain}`}>Interpretation</label>
                        <textarea
                          id={`interp-${interp.domain}`}
                          name="interpretation"
                          placeholder="Click 'Generate' to create an AI interpretation, or type your own..."
                          rows="5"
                        ></textarea>
                      </div>

                      <div class="field">
                        <label for={`question-${interp.domain}`}>Introspection Question</label>
                        <textarea
                          id={`question-${interp.domain}`}
                          name="question"
                          placeholder="The question that will prompt your reflection..."
                          rows="2"
                        ></textarea>
                      </div>

                      <div class="form-footer">
                        <button type="button" class="btn btn-secondary generate-btn" data-domain={interp.domain}>
                          <span class="btn-icon">✨</span>
                          Generate
                        </button>
                      </div>
                    </div>
                  )}
                </div>

                <div class="loading-overlay" style="display: none;">
                  <div class="spinner"></div>
                  <span>Generating interpretation...</span>
                </div>
              </div>
            );
          })}
        </div>

        <div class="form-actions">
          <a href={`/practice/${date}`} class="btn">Cancel</a>
          <button type="button" class="btn btn-primary" id="save-all-btn">
            Save All Preparations
          </button>
        </div>
      </div>
    )}
  </div>
</Layout>

<script define:vars={{
  date,
  planetaryCard: data?.planetary_card,
  planetaryCardDetail: data?.planetary_card_detail,
  domainCardsDetail: data?.domain_cards_detail
}}>
  const API_BASE = 'https://neo4jmiddleware.robin-alligator.ts.net';

  const generateAllBtn = document.getElementById('generate-all-btn');
  const saveAllBtn = document.getElementById('save-all-btn');

  // Get all domain forms that need preparation
  const getDomainForms = () => {
    return Array.from(document.querySelectorAll('.interpretation-form:not(.is-ready)'));
  };

  async function generateInterpretation(domain, domainCard) {
    const form = document.querySelector(`.interpretation-form[data-domain="${domain}"]`);
    if (!form) return;

    const overlay = form.querySelector('.loading-overlay');
    const interpTextarea = form.querySelector(`#interp-${domain}`);
    const questionTextarea = form.querySelector(`#question-${domain}`);

    if (overlay) overlay.style.display = 'flex';

    try {
      const response = await fetch('/api/generate-interpretation', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          domain,
          planetary_card: planetaryCard,
          planetary_card_detail: planetaryCardDetail || {},
          domain_card: domainCard,
          domain_card_detail: domainCardsDetail?.[domain] || {}
        })
      });

      if (!response.ok) {
        const error = await response.json().catch(() => ({}));
        throw new Error(error.error || `Generation failed: ${response.status}`);
      }

      const result = await response.json();

      if (interpTextarea) interpTextarea.value = result.interpretation;
      if (questionTextarea) questionTextarea.value = result.introspection_question;

      // Mark as modified
      form.classList.add('is-modified');

    } catch (err) {
      console.error(`Error generating ${domain}:`, err);
      alert(`Failed to generate ${domain} interpretation: ${err.message}`);
    } finally {
      if (overlay) overlay.style.display = 'none';
    }
  }

  async function generateAll() {
    const forms = getDomainForms();
    if (forms.length === 0) {
      alert('All interpretations are already prepared.');
      return;
    }

    generateAllBtn.disabled = true;
    generateAllBtn.innerHTML = '<span class="spinner-small"></span> Generating...';

    for (const form of forms) {
      const domain = form.dataset.domain;
      const domainCard = form.dataset.domainCard;
      await generateInterpretation(domain, domainCard);
    }

    generateAllBtn.disabled = false;
    generateAllBtn.innerHTML = '<span class="btn-icon">✨</span> Generate All Interpretations';
  }

  async function prepareInterpretation(interpretationId, interpretation, question) {
    const response = await fetch(`${API_BASE}/sacred-journey/daily/interpretation/${interpretationId}/prepare`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        prepared_interpretation: interpretation,
        introspection_question: question
      })
    });

    if (!response.ok) {
      const error = await response.json().catch(() => ({}));
      throw new Error(error.detail || `Failed to prepare: ${response.status}`);
    }

    return response.json();
  }

  async function saveAll() {
    const forms = getDomainForms();
    let successCount = 0;
    let errors = [];

    saveAllBtn.disabled = true;
    saveAllBtn.textContent = 'Saving...';

    for (const form of forms) {
      const domain = form.dataset.domain;
      const interpretationId = form.dataset.interpretationId;
      const interpTextarea = form.querySelector(`#interp-${domain}`);
      const questionTextarea = form.querySelector(`#question-${domain}`);
      const statusBadge = form.querySelector('.status-badge');

      const interpretation = interpTextarea?.value?.trim();
      const question = questionTextarea?.value?.trim();

      if (!interpretation || !question) {
        errors.push(`${domain}: Missing interpretation or question`);
        continue;
      }

      try {
        await prepareInterpretation(interpretationId, interpretation, question);
        successCount++;

        // Update UI to show success
        if (statusBadge) {
          statusBadge.textContent = 'ready';
          statusBadge.className = 'status-badge status-ready';
        }
        form.classList.add('is-ready');
        form.classList.remove('is-modified');

      } catch (err) {
        errors.push(`${domain}: ${err.message}`);
      }
    }

    saveAllBtn.disabled = false;
    saveAllBtn.textContent = 'Save All Preparations';

    if (errors.length > 0) {
      alert(`Saved ${successCount} interpretation(s).\n\nErrors:\n${errors.join('\n')}`);
    } else if (successCount > 0) {
      // Show success and ask where to go next
      const goToPending = confirm(
        `Successfully prepared ${successCount} interpretation(s)!\n\n` +
        `Your introspection questions are now ready.\n\n` +
        `Click OK to respond to them now, or Cancel to return to today's practice.`
      );
      if (goToPending) {
        window.location.href = `/practice/pending`;
      } else {
        window.location.href = `/practice/${date}`;
      }
    } else {
      alert('No interpretations to save. Generate interpretations first.');
    }
  }

  // Event listeners
  generateAllBtn?.addEventListener('click', generateAll);
  saveAllBtn?.addEventListener('click', saveAll);

  // Per-domain generate buttons
  document.querySelectorAll('.generate-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const domain = btn.dataset.domain;
      const form = btn.closest('.interpretation-form');
      const domainCard = form?.dataset.domainCard;
      if (domain && domainCard) {
        generateInterpretation(domain, domainCard);
      }
    });
  });
</script>

<style>
  .prepare-page {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: var(--space-xl);
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .back-link:hover {
    color: var(--color-gold);
  }

  .subtitle {
    color: var(--color-text-muted);
    margin: 0;
  }

  .planetary-card {
    color: var(--color-gold);
    margin-top: var(--space-sm);
  }

  .action-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xl);
    padding: var(--space-md) var(--space-lg);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
  }

  .status-summary {
    color: var(--color-text-muted);
  }

  .needs-prep {
    color: var(--color-gold);
  }

  .interpretations-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .interpretation-form {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    border-left: 4px solid var(--domain-color, var(--color-border));
    overflow: hidden;
    position: relative;
  }

  .interpretation-form.domain-body { --domain-color: var(--color-accent-body); }
  .interpretation-form.domain-mind { --domain-color: var(--color-accent-mind); }
  .interpretation-form.domain-heart { --domain-color: var(--color-accent-heart); }
  .interpretation-form.domain-spirit { --domain-color: var(--color-accent-spirit); }

  .interpretation-form.is-ready {
    opacity: 0.7;
  }

  .interpretation-form.is-modified {
    border-color: var(--color-gold);
  }

  .form-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-md) var(--space-lg);
    background: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
  }

  .header-left {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
  }

  .form-header h3 {
    margin: 0;
    color: var(--domain-color);
    font-family: var(--font-display);
  }

  .domain-card-name {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .status-badge {
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    background: rgba(201, 162, 39, 0.1);
    color: var(--color-gold-dim);
  }

  .status-badge.status-ready,
  .status-badge.status-responded,
  .status-badge.status-complete {
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
  }

  .form-body {
    padding: var(--space-lg);
  }

  .field {
    margin-bottom: var(--space-md);
  }

  .field:last-child {
    margin-bottom: 0;
  }

  .field label {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }

  .field textarea {
    width: 100%;
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    color: var(--color-text);
    resize: vertical;
  }

  .field textarea:focus {
    outline: none;
    border-color: var(--color-gold);
  }

  .field textarea::placeholder {
    color: var(--color-text-dim);
  }

  .readonly-text {
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    white-space: pre-wrap;
  }

  .readonly-text.question {
    font-style: italic;
    color: var(--color-gold-dim);
  }

  .form-footer {
    display: flex;
    justify-content: flex-end;
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .form-actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-md);
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .btn-icon {
    margin-right: var(--space-xs);
  }

  .btn-secondary {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .btn-secondary:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .loading-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    color: var(--color-gold);
    z-index: 10;
  }

  .spinner {
    width: 32px;
    height: 32px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-gold);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  .spinner-small {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-gold);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-right: var(--space-xs);
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .error-state,
  .all-ready-state {
    text-align: center;
    padding: var(--space-2xl);
    background: var(--color-bg-elevated);
    border: 1px dashed var(--color-border);
    border-radius: var(--card-radius);
  }

  .all-ready-state h2 {
    color: #22c55e;
  }

  .action-buttons {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    margin-top: var(--space-lg);
  }

  @media (max-width: 768px) {
    .action-bar {
      flex-direction: column;
      gap: var(--space-md);
      text-align: center;
    }

    .form-actions {
      flex-direction: column;
    }

    .header-left {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }
</style>
