---
/**
 * Respond to Interpretation
 *
 * Server-rendered form for submitting a response to a single domain interpretation.
 * The [id] param is an interpretation_id UUID.
 *
 * V2: There is no dedicated "get single interpretation" endpoint. Context is derived
 * from optional query params (?entry=<entry_id>&domain=<domain>) which link back to
 * the parent entry's interpretations status.
 *
 * POST: calls respondToInterpretation(interpId, responseText) and redirects back.
 */
import Layout from '../../../layouts/Layout.astro';
import { sacredJourney } from '../../../lib/sacred-journey';
import type {
  ProgressionEntryResponse,
  AllInterpretationsStatusResponse,
  InterpretationStatusItem,
} from '../../../lib/sacred-journey';

const { id: interpId } = Astro.params;

// Validate that the param looks like a UUID
const uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
if (!interpId || !uuidRegex.test(interpId)) {
  return Astro.redirect('/');
}

// Handle POST — submit the user's response
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const responseText = formData.get('response_text') as string;
  const returnTo = formData.get('return_to') as string || '/';

  if (responseText?.trim()) {
    try {
      await sacredJourney.respondToInterpretation(interpId, responseText.trim());
    } catch (e) {
      console.error('Respond error:', e);
    }
  }

  return Astro.redirect(returnTo);
}

// GET — load optional context from query params
const url = new URL(Astro.request.url);
const entryId = url.searchParams.get('entry') ?? null;
const domainParam = url.searchParams.get('domain') ?? null;

let entry: ProgressionEntryResponse | null = null;
let interps: AllInterpretationsStatusResponse | null = null;
let interp: InterpretationStatusItem | null = null;
let error: string | null = null;

if (entryId) {
  try {
    entry = await sacredJourney.getEntry(entryId);
    const status = await sacredJourney.getInterpretationsStatus(entryId);
    interps = status;
    interp = status.interpretations.find(i => i.interpretation_id === interpId) ?? null;
  } catch (e) {
    error = e instanceof Error ? e.message : 'Failed to load entry context';
  }
}

// Derive display values
const planetName = entry?.planet ?? '';
const sequence = entry?.sequence ?? 0;
const planetaryCard = entry?.planetary_card ?? '';
const domainCards = entry?.domain_cards ?? {};
const domain = interp?.domain ?? domainParam ?? null;
const domainCard = domain ? (domainCards[domain] || '') : '';
const interpStatus = interp?.status ?? null;

// Determine where to redirect after responding
const returnTo = entryId
  ? `/practice/session/${entryId}`
  : '/';

// If this interpretation has already been responded to, show that info
const alreadyResponded = interpStatus === 'responded' || interpStatus === 'evaluated' || interpStatus === 'complete';
---

<Layout title={`Respond${domain ? ` — ${domain}` : ''} — Paths of Reverence`}>
  <div class="respond-page">
    <header class="page-header">
      <a href={entryId ? `/practice/session/${entryId}` : '/'} class="back-link">
        &larr; {entryId ? 'Back to Session' : 'Home'}
      </a>
      <h1>Reflect &amp; Respond</h1>
      {(planetName || domain) && (
        <div class="header-meta">
          {planetName && (
            <span class="planet-name">{planetName} &mdash; Entry {sequence} of 7</span>
          )}
          {planetaryCard && (
            <span class="planetary-card-name">{planetaryCard}</span>
          )}
        </div>
      )}
    </header>

    {error ? (
      <div class="error-state">
        <h2>Unable to Load</h2>
        <p>{error}</p>
        <a href="/" class="btn">Home</a>
      </div>
    ) : alreadyResponded ? (
      <div class="already-responded-state">
        <div class="success-icon">&#10022;</div>
        <h2>Already Responded</h2>
        <p>
          This {domain ? `${domain} ` : ''}interpretation has already been responded to.
          {interpStatus === 'evaluated' ? ' It has been evaluated.' : ''}
          {interpStatus === 'complete' ? ' It is complete.' : ''}
        </p>
        <div class="action-buttons">
          {entryId && (
            <a href={`/practice/session/${entryId}`} class="btn btn-primary">Back to Session</a>
          )}
          <a href="/" class="btn">Home</a>
        </div>
      </div>
    ) : (
      <div class="respond-content">
        {/* Domain context */}
        {domain && (
          <section class="domain-context">
            <div class={`domain-badge domain-${domain.toLowerCase()}`}>
              {domain}
            </div>
            {domainCard && (
              <div class="domain-card-display">
                <span class="card-label">Domain Card</span>
                <span class="card-name">{domainCard}</span>
              </div>
            )}
          </section>
        )}

        {/* Response form */}
        <section class="response-section">
          <h2>Your Reflection</h2>
          <form method="POST" class="response-form">
            <input type="hidden" name="return_to" value={returnTo} />
            <textarea
              name="response_text"
              placeholder={domain
                ? `Take a moment to reflect on the ${domain} domain... What arises for you?`
                : 'Take a moment to reflect... What arises for you?'}
              rows="8"
              required
            ></textarea>

            <div class="form-footer">
              <p class="guidance">
                Write freely. Your response informs both your practice and the evolving
                understanding of these archetypal patterns.
              </p>
              <button type="submit" class="btn btn-primary">
                Submit Response
              </button>
            </div>
          </form>
        </section>

        {/* Navigation */}
        <div class="respond-navigation">
          <a href={entryId ? `/practice/session/${entryId}` : '/'} class="btn">
            Cancel
          </a>
        </div>
      </div>
    )}
  </div>
</Layout>

<style>
  .respond-page {
    max-width: 700px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: var(--space-2xl);
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .back-link:hover {
    color: var(--color-gold);
  }

  .header-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }

  .planet-name {
    color: var(--color-text-muted);
  }

  .planetary-card-name {
    color: var(--color-gold);
    font-family: var(--font-display);
    font-size: 1rem;
  }

  /* Domain context */
  .domain-context {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
    padding: var(--space-lg);
    background: var(--color-bg-elevated);
    border-radius: var(--card-radius);
    border: 1px solid var(--color-border);
  }

  .domain-badge {
    font-family: var(--font-display);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: var(--space-xs) var(--space-sm);
    border-radius: 4px;
    background: var(--color-bg-card);
  }

  .domain-badge.domain-physical { color: var(--color-accent-body); }
  .domain-badge.domain-emotional { color: var(--color-accent-heart); }
  .domain-badge.domain-mental { color: var(--color-accent-mind); }
  .domain-badge.domain-spiritual { color: var(--color-accent-spirit); }

  .domain-card-display {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .card-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-dim);
  }

  .card-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-gold);
  }

  /* Response section */
  .response-section {
    margin-bottom: var(--space-2xl);
  }

  h2 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  textarea {
    width: 100%;
    padding: var(--space-md);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    color: var(--color-text);
    resize: vertical;
    min-height: 200px;
  }

  textarea:focus {
    outline: none;
    border-color: var(--color-gold);
  }

  textarea::placeholder {
    color: var(--color-text-dim);
  }

  .form-footer {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-lg);
    margin-top: var(--space-md);
  }

  .guidance {
    font-size: 0.9rem;
    color: var(--color-text-dim);
    margin: 0;
    max-width: 400px;
  }

  button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Already responded state */
  .already-responded-state,
  .error-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 400px;
    text-align: center;
    padding: var(--space-2xl);
    background: var(--color-bg-elevated);
    border: 1px dashed var(--color-border);
    border-radius: var(--card-radius);
  }

  .success-icon {
    font-size: 4rem;
    color: var(--color-gold);
    margin-bottom: var(--space-md);
  }

  .action-buttons {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  /* Navigation */
  .respond-navigation {
    display: flex;
    justify-content: flex-start;
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  /* Responsive */
  @media (max-width: 600px) {
    .domain-context {
      flex-direction: column;
      align-items: flex-start;
    }

    .form-footer {
      flex-direction: column;
    }

    .header-meta {
      flex-direction: column;
      align-items: flex-start;
    }

    .action-buttons {
      flex-direction: column;
    }
  }
</style>
