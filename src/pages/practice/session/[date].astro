---
/**
 * Sacred Journey Session Page
 *
 * Server-rendered form-based session for responding to domain interpretations
 * and synthesizing an entry. The [date] param receives an entry_id UUID (V2).
 *
 * Flow:
 *   1. Displays entry header (planet, sequence, planetary card)
 *   2. Shows context (previous synthesis, same-planet-previous-cycle synthesis)
 *   3. For each domain interpretation, shows status and response form when ready
 *   4. After all domains are responded, shows synthesis form
 *   5. Synthesis submits and redirects to integration page
 */
import Layout from '../../../layouts/Layout.astro';
import { sacredJourney } from '../../../lib/sacred-journey';
import type {
  ProgressionEntryResponse,
  EntryContextResponse,
  AllInterpretationsStatusResponse,
} from '../../../lib/sacred-journey';
import { DOMAINS } from '../../../lib/domain-utils';

const { date: entryId } = Astro.params;

// Validate that the param looks like a UUID
const uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
if (!entryId || !uuidRegex.test(entryId)) {
  return Astro.redirect('/');
}

// Handle POST actions
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action') as string;

  if (action === 'respond') {
    // Submit a response for one domain interpretation
    const interpId = formData.get('interpretation_id') as string;
    const responseText = formData.get('response_text') as string;
    if (interpId && responseText) {
      try {
        await sacredJourney.respondToInterpretation(interpId, responseText);
      } catch (e) {
        console.error('Respond error:', e);
      }
    }
    return Astro.redirect(`/practice/session/${entryId}`);
  }

  if (action === 'synthesize') {
    // Synthesize the entry after all domains are responded to
    const synthesisContent = formData.get('synthesis_content') as string;
    if (synthesisContent) {
      try {
        await sacredJourney.synthesizeEntry(entryId, { synthesis_content: synthesisContent });
        // After synthesis, entry transitions to 'integrating'
        return Astro.redirect(`/practice/integrate/${entryId}`);
      } catch (e) {
        console.error('Synthesize error:', e);
      }
    }
    return Astro.redirect(`/practice/session/${entryId}`);
  }
}

// GET — load entry data, context, and interpretation statuses
let entry: ProgressionEntryResponse | null = null;
let context: EntryContextResponse | null = null;
let interps: AllInterpretationsStatusResponse | null = null;
let error: string | null = null;

try {
  entry = await sacredJourney.getEntry(entryId);
  context = await sacredJourney.getEntryContext(entryId);
  interps = await sacredJourney.getInterpretationsStatus(entryId);
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load session data';
}

// Derive display values
const planetName = entry?.planet ?? '';
const sequence = entry?.sequence ?? 0;
const entryStatus = entry?.status ?? 'available';
const planetaryCard = entry?.planetary_card ?? '';
const domainCards = entry?.domain_cards ?? {};
const cycleId = entry?.cycle_id ?? context?.cycle_id ?? '';
const interpretations = interps?.interpretations ?? [];
const allComplete = interps?.all_complete ?? false;
const completionCount = interps?.completion_count ?? 0;

// Context from previous entries
const previousSynthesis = context?.previous_entry?.synthesis ?? null;
const samePlanetSynthesis = context?.same_planet_previous_cycle?.synthesis ?? null;

// Determine how many domains have been responded to (responded, evaluated, or complete)
const respondedCount = interpretations.filter(
  i => i.status === 'responded' || i.status === 'evaluated' || i.status === 'complete'
).length;
const allResponded = respondedCount >= DOMAINS.length && interpretations.length >= DOMAINS.length;

// Check if any domains still need preparation
const pendingDomains = DOMAINS.filter(d => {
  const interp = interpretations.find(i => i.domain === d);
  return !interp || interp.status === 'pending';
});
const hasPendingDomains = pendingDomains.length > 0;

// Status helpers
function statusLabel(status: string): string {
  switch (status) {
    case 'pending': return 'Pending';
    case 'responded': return 'Responded';
    case 'evaluated': return 'Evaluated';
    case 'complete': return 'Complete';
    default: return status;
  }
}

function statusIcon(status: string): string {
  switch (status) {
    case 'pending': return '\u25CB';       // ○
    case 'responded': return '\u2713';     // ✓
    case 'evaluated': return '\u2713\u2713'; // ✓✓
    case 'complete': return '\u2726';      // ✦
    default: return '';
  }
}
---

<Layout title={`Session — ${planetName || 'Entry'} ${sequence} — Paths of Reverence`}>
  <div class="session-page">
    <header class="page-header">
      <a href={`/practice/${entryId}`} class="back-link">&larr; Back to Entry</a>
      <h1>Sacred Journey Session</h1>
      <div class="header-meta">
        <span class="planet-name">{planetName} &mdash; Entry {sequence} of 7</span>
        {planetaryCard && (
          <span class="planetary-card-name">{planetaryCard}</span>
        )}
      </div>
    </header>

    {error ? (
      <div class="error-state">
        <h2>Unable to Load</h2>
        <p>{error}</p>
        <a href="/" class="btn">Home</a>
      </div>
    ) : !entry ? (
      <div class="error-state">
        <h2>Entry Not Found</h2>
        <p>This entry could not be found.</p>
        <a href="/" class="btn btn-primary">Home</a>
      </div>
    ) : (
      <div class="session-content">
        {/* Sidebar: cards + context */}
        <aside class="cards-panel">
          <div class="planetary-card-display">
            <span class="card-label">Planetary Card</span>
            <span class="card-name">{planetaryCard || 'Not assigned'}</span>
          </div>

          <div class="domain-cards-display">
            <h3>Domain Cards</h3>
            <div class="domain-list">
              {DOMAINS.map((domain) => (
                <div class={`domain-item domain-${domain.toLowerCase()}`}>
                  <span class="domain-label">{domain}</span>
                  <span class="domain-card">{domainCards[domain] || '\u2014'}</span>
                </div>
              ))}
            </div>
          </div>

          {previousSynthesis && (
            <div class="context-panel">
              <h3>Previous Entry Synthesis</h3>
              <p class="context-text">{previousSynthesis}</p>
            </div>
          )}

          {samePlanetSynthesis && (
            <div class="context-panel">
              <h3>Same Planet — Previous Cycle</h3>
              <p class="context-text">{samePlanetSynthesis}</p>
            </div>
          )}

          <div class="progress-summary">
            <span class="progress-label">Progress</span>
            <span class="progress-count">{respondedCount} of {DOMAINS.length} domains responded</span>
          </div>
        </aside>

        {/* Main content: domain interpretations + synthesis */}
        <main class="main-panel">
          {/* Domain Interpretations */}
          <section class="interpretations-section">
            <h2>Domain Reflections</h2>

            {hasPendingDomains && (
              <div class="needs-preparation-notice">
                <p>
                  {pendingDomains.length} domain{pendingDomains.length !== 1 ? 's' : ''} need{pendingDomains.length === 1 ? 's' : ''} preparation before you can respond.
                </p>
                <a href={`/practice/prepare/${entryId}`} class="btn btn-secondary">
                  Prepare Interpretations
                </a>
              </div>
            )}

            <div class="domains-list">
              {DOMAINS.map((domain) => {
                const interp = interpretations.find(i => i.domain === domain);
                const status = interp?.status ?? 'pending';
                const interpId = interp?.interpretation_id ?? '';
                const domainCard = domainCards[domain] || '';
                const isPending = status === 'pending';
                const isResponded = status === 'responded';
                const isEvaluated = status === 'evaluated';
                const isComplete = status === 'complete';
                const needsResponse = !isPending && !isResponded && !isEvaluated && !isComplete;

                return (
                  <div class={`domain-block domain-${domain.toLowerCase()} status-${status}`}>
                    <div class="domain-header">
                      <div class="domain-header-left">
                        <h3>{domain}</h3>
                        {domainCard && <span class="domain-card-label">{domainCard}</span>}
                      </div>
                      <span class={`status-badge status-${status}`}>
                        {statusIcon(status)} {statusLabel(status)}
                      </span>
                    </div>

                    <div class="domain-body">
                      {isPending && !interpId && (
                        <div class="pending-message">
                          <p>This domain needs preparation before you can respond.</p>
                          <a href={`/practice/prepare/${entryId}`} class="btn btn-sm">Prepare</a>
                        </div>
                      )}

                      {isPending && interpId && (
                        <div class="ready-to-respond">
                          <p>This domain is prepared and ready for your reflection.</p>
                          <form method="POST" class="response-form">
                            <input type="hidden" name="action" value="respond" />
                            <input type="hidden" name="interpretation_id" value={interpId} />
                            <label for={`response-${domain}`} class="response-label">
                              Your reflection for {domain}:
                            </label>
                            <textarea
                              id={`response-${domain}`}
                              name="response_text"
                              placeholder={`What arises for you in the ${domain} domain today?`}
                              rows="6"
                              required
                            ></textarea>
                            <div class="form-actions">
                              <button type="submit" class="btn btn-primary">Submit Response</button>
                            </div>
                          </form>
                        </div>
                      )}

                      {isResponded && (
                        <div class="responded-message">
                          <p>Response submitted — awaiting evaluation.</p>
                          {interpId && (
                            <a href={`/practice/respond/${interpId}`} class="btn btn-sm">View Response</a>
                          )}
                        </div>
                      )}

                      {isEvaluated && (
                        <div class="evaluated-message">
                          <p>Evaluated — awaiting completion.</p>
                        </div>
                      )}

                      {isComplete && (
                        <div class="complete-message">
                          <span class="checkmark">&#10003;</span>
                          <span>Complete</span>
                        </div>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </section>

          {/* Synthesis Form — shown when all domains are responded */}
          {allResponded && !allComplete && entryStatus !== 'integrating' && entryStatus !== 'complete' ? (
            <section class="synthesis-section">
              <h2>Entry Synthesis</h2>
              <p class="synthesis-intro">
                All domain reflections have been submitted. Write a synthesis that weaves together
                the threads from each domain into a unified understanding.
              </p>
              <form method="POST" class="synthesis-form">
                <input type="hidden" name="action" value="synthesize" />
                <textarea
                  name="synthesis_content"
                  placeholder="Weave together the insights from Physical, Emotional, Mental, and Spiritual domains..."
                  rows="10"
                  required
                ></textarea>
                <div class="form-actions">
                  <button type="submit" class="btn btn-primary">
                    Synthesize &amp; Continue
                  </button>
                </div>
              </form>
            </section>
          ) : allComplete || entryStatus === 'integrating' || entryStatus === 'complete' ? (
            <section class="completed-section">
              <div class="completed-badge">
                <span class="completed-icon">&#10022;</span>
                <div>
                  <h2>
                    {entryStatus === 'integrating' ? 'Integration Phase' :
                     entryStatus === 'complete' ? 'Entry Complete' :
                     'All Domains Complete'}
                  </h2>
                  <p>
                    {entryStatus === 'integrating'
                      ? 'This entry has been synthesized and is now in the integration phase.'
                      : entryStatus === 'complete'
                      ? 'This entry has been fully completed.'
                      : 'All domain interpretations are complete. You can now synthesize this entry.'}
                  </p>
                </div>
              </div>
              <div class="completed-actions">
                {entryStatus === 'integrating' && (
                  <a href={`/practice/integrate/${entryId}`} class="btn btn-primary">Go to Integration</a>
                )}
                <a href={`/practice/${entryId}`} class="btn">Back to Entry</a>
                {cycleId && (
                  <a href={`/practice/cycle/${cycleId}`} class="btn">View Cycle</a>
                )}
              </div>
            </section>
          ) : null}

          {/* Navigation */}
          <div class="session-navigation">
            <a href={`/practice/${entryId}`} class="btn">Back to Entry</a>
            {hasPendingDomains && (
              <a href={`/practice/prepare/${entryId}`} class="btn btn-primary">Prepare Domains</a>
            )}
          </div>
        </main>
      </div>
    )}
  </div>
</Layout>

<style>
  .session-page {
    max-width: 1100px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: var(--space-xl);
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .back-link:hover {
    color: var(--color-gold);
  }

  .header-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }

  .planet-name {
    color: var(--color-text-muted);
  }

  .planetary-card-name {
    color: var(--color-gold);
    font-family: var(--font-display);
    font-size: 1rem;
  }

  /* Session layout */
  .session-content {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  /* Cards Panel (sidebar) */
  .cards-panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    position: sticky;
    top: var(--space-lg);
  }

  .planetary-card-display {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-gold);
    border-radius: var(--card-radius);
    padding: var(--space-lg);
    text-align: center;
  }

  .card-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-dim);
    margin-bottom: var(--space-xs);
  }

  .card-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-gold);
  }

  .domain-cards-display {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-md);
  }

  .domain-cards-display h3 {
    font-size: 0.85rem;
    margin-bottom: var(--space-md);
    color: var(--color-text-muted);
  }

  .domain-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .domain-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-xs) var(--space-sm);
    border-radius: 4px;
    background: var(--color-bg);
  }

  .domain-label {
    font-family: var(--font-display);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .domain-item.domain-physical .domain-label { color: var(--color-accent-body); }
  .domain-item.domain-emotional .domain-label { color: var(--color-accent-heart); }
  .domain-item.domain-mental .domain-label { color: var(--color-accent-mind); }
  .domain-item.domain-spiritual .domain-label { color: var(--color-accent-spirit); }

  .domain-card {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .context-panel {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-md);
  }

  .context-panel h3 {
    font-size: 0.85rem;
    margin-bottom: var(--space-sm);
    color: var(--color-text-muted);
  }

  .context-text {
    font-size: 0.85rem;
    color: var(--color-text-dim);
    line-height: 1.5;
    max-height: 150px;
    overflow-y: auto;
    margin: 0;
    white-space: pre-wrap;
  }

  .progress-summary {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-md);
    text-align: center;
  }

  .progress-label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-dim);
    margin-bottom: var(--space-xs);
  }

  .progress-count {
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--color-gold);
  }

  /* Main Panel */
  .main-panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .interpretations-section h2,
  .synthesis-section h2,
  .completed-section h2 {
    margin-bottom: var(--space-md);
  }

  /* Needs preparation notice */
  .needs-preparation-notice {
    background: var(--color-bg-elevated);
    border: 1px dashed var(--color-gold-dim);
    border-radius: var(--card-radius);
    padding: var(--space-lg);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .needs-preparation-notice p {
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Domain blocks */
  .domains-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .domain-block {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    border-left: 4px solid var(--domain-color, var(--color-border));
    overflow: hidden;
  }

  .domain-block.domain-physical { --domain-color: var(--color-accent-body); }
  .domain-block.domain-emotional { --domain-color: var(--color-accent-heart); }
  .domain-block.domain-mental { --domain-color: var(--color-accent-mind); }
  .domain-block.domain-spiritual { --domain-color: var(--color-accent-spirit); }

  .domain-block.status-responded,
  .domain-block.status-evaluated,
  .domain-block.status-complete {
    opacity: 0.8;
  }

  .domain-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-md) var(--space-lg);
    background: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
  }

  .domain-header-left {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
  }

  .domain-header h3 {
    margin: 0;
    color: var(--domain-color);
    font-family: var(--font-display);
  }

  .domain-card-label {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .status-badge {
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    background: var(--color-bg);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .status-badge.status-pending {
    background: rgba(201, 162, 39, 0.1);
    color: var(--color-gold-dim);
  }

  .status-badge.status-responded {
    background: rgba(201, 162, 39, 0.2);
    color: var(--color-gold);
  }

  .status-badge.status-evaluated {
    background: rgba(138, 130, 180, 0.2);
    color: #a89fd4;
  }

  .status-badge.status-complete {
    background: rgba(124, 152, 133, 0.2);
    color: var(--color-accent-body);
  }

  .domain-body {
    padding: var(--space-lg);
  }

  .pending-message,
  .responded-message,
  .evaluated-message {
    color: var(--color-text-dim);
    font-size: 0.9rem;
  }

  .pending-message p,
  .responded-message p,
  .evaluated-message p {
    margin: 0 0 var(--space-sm);
  }

  .complete-message {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-accent-body);
  }

  .checkmark {
    font-size: 1.2rem;
  }

  /* Response form */
  .response-form {
    margin-top: var(--space-md);
  }

  .response-label {
    display: block;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .ready-to-respond p {
    color: var(--color-text-dim);
    margin: 0 0 var(--space-sm);
  }

  textarea {
    width: 100%;
    padding: var(--space-md);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    color: var(--color-text);
    resize: vertical;
    min-height: 120px;
  }

  textarea:focus {
    outline: none;
    border-color: var(--color-gold);
  }

  textarea::placeholder {
    color: var(--color-text-dim);
  }

  .form-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: var(--space-md);
  }

  /* Synthesis section */
  .synthesis-section {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-gold-dim);
    border-radius: var(--card-radius);
    padding: var(--space-xl);
  }

  .synthesis-intro {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .synthesis-form textarea {
    min-height: 200px;
  }

  /* Completed section */
  .completed-section {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: var(--space-xl);
    text-align: center;
  }

  .completed-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .completed-icon {
    font-size: 2.5rem;
    color: var(--color-gold);
  }

  .completed-badge h2 {
    margin-bottom: var(--space-xs);
  }

  .completed-badge p {
    color: var(--color-text-muted);
    margin: 0;
  }

  .completed-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
  }

  /* Btn utilities */
  .btn-sm {
    font-size: 0.8rem;
    padding: 4px 12px;
    display: inline-block;
  }

  .btn-secondary {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .btn-secondary:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  /* Session navigation */
  .session-navigation {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  /* States */
  .error-state {
    text-align: center;
    padding: var(--space-2xl);
    background: var(--color-bg-elevated);
    border: 1px dashed var(--color-border);
    border-radius: var(--card-radius);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .session-content {
      grid-template-columns: 1fr;
    }

    .cards-panel {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-md);
    }

    .planetary-card-display,
    .domain-cards-display,
    .context-panel,
    .progress-summary {
      flex: 1;
      min-width: 200px;
    }

    .context-panel {
